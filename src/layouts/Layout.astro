---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  keywords?: string;
  ogImage?: string;
}

const {
  title = 'SplitWhat — The No-Login Bill Splitter',
  description = 'Split What? Easily split bills, travel expenses, and subscription costs with friends. A free, client-side, no-login alternative to Splitwise. Completely offline-capable.',
  keywords = 'split bills, travel expense splitter, subscription bill splitter, splitwise alternative, no login bill splitter, free bill splitter',
  ogImage = '/og-image.png'
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site || 'https://splitwhat.vercel.app').toString();
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    
    <!-- Primary Meta Tags -->
    <title>{title}</title>
    <meta name="title" content={title} />
    <meta name="description" content={description} />
    <meta name="keywords" content={keywords} />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={canonicalURL} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={ogImage} />

    <!-- Preload fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400&display=swap" rel="stylesheet" />
  </head>
  <body class="flex flex-col min-h-screen bg-canvas-soft text-ink font-sans selection:bg-primary selection:text-on-primary">
    <!-- Navbar -->
    <header class="sticky top-0 z-40 w-full border-b border-hairline bg-canvas/80 backdrop-blur-md">
      <div class="mx-auto flex h-16 max-w-7xl items-center justify-between px-4 sm:px-6 lg:px-8">
        <div class="flex items-center gap-6">
          <a href="/" class="flex items-center gap-2 text-xl font-semibold tracking-tighter hover:opacity-90">
            <!-- Vercel logo style triangle pointing up -->
            <svg class="h-5 w-5 fill-current" viewBox="0 0 115 115" xmlns="http://www.w3.org/2000/svg">
              <path d="M57.5 0L115 100H0L57.5 0Z"></path>
            </svg>
            <span class="font-mono text-sm tracking-tight text-mute font-normal">/</span>
            <span>SplitWhat</span>
          </a>
          <nav class="hidden md:flex items-center gap-1">
            <a href="/" class="rounded-full px-3 py-1.5 text-sm font-medium text-body hover:bg-canvas-soft-2 hover:text-ink transition-colors">Features</a>
            <a href="/app" class="rounded-full px-3 py-1.5 text-sm font-medium text-body hover:bg-canvas-soft-2 hover:text-ink transition-colors font-mono">/app</a>
          </nav>
        </div>
        
        <div class="flex items-center gap-3">
          <a 
            href="/app" 
            class="inline-flex h-9 items-center justify-center rounded-full bg-primary px-5 text-sm font-semibold text-on-primary hover:bg-primary/90 transition-colors shadow-vercel-sm"
          >
            Launch App
          </a>
        </div>
      </div>
    </header>

    <!-- Main Content -->
    <main class="flex-grow relative">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="border-t border-hairline bg-canvas">
      <div class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8 lg:py-16">
        <div class="xl:grid xl:grid-cols-3 xl:gap-8">
          <div class="space-y-4">
            <a href="/" class="flex items-center gap-2 text-lg font-semibold tracking-tighter">
              <svg class="h-4 w-4 fill-current" viewBox="0 0 115 115" xmlns="http://www.w3.org/2000/svg">
                <path d="M57.5 0L115 100H0L57.5 0Z"></path>
              </svg>
              <span>SplitWhat</span>
            </a>
            <p class="text-sm text-body max-w-xs">
              Vercel-style, client-side only bill splitter. Secure, fast, and free. No servers, no tracking.
            </p>
            <div class="font-mono text-xs text-mute">
              <span>MADE BY ANTIGRAVITY</span>
            </div>
          </div>
          <div class="mt-12 grid grid-cols-2 gap-8 xl:col-span-2 xl:mt-0">
            <div class="md:grid md:grid-cols-2 md:gap-8">
              <div>
                <h3 class="font-mono text-xs font-semibold uppercase tracking-wider text-mute">Product</h3>
                <ul class="mt-4 space-y-2">
                  <li>
                    <a href="/app" class="text-sm text-body hover:text-ink">Split App</a>
                  </li>
                  <li>
                    <a href="/" class="text-sm text-body hover:text-ink">Features</a>
                  </li>
                  <li>
                    <a href="/app?g=copy" class="text-sm text-body hover:text-ink font-mono text-[11px] text-mute hover:text-ink">/app?g=demo</a>
                  </li>
                </ul>
              </div>
              <div class="mt-12 md:mt-0">
                <h3 class="font-mono text-xs font-semibold uppercase tracking-wider text-mute">Use Cases</h3>
                <ul class="mt-4 space-y-2">
                  <li>
                    <span class="text-sm text-body">Travel Splitting</span>
                  </li>
                  <li>
                    <span class="text-sm text-body">Subscription Sharing</span>
                  </li>
                  <li>
                    <span class="text-sm text-body">Roommate Expenses</span>
                  </li>
                </ul>
              </div>
            </div>
            <div class="md:grid md:grid-cols-1 md:gap-8">
              <div>
                <h3 class="font-mono text-xs font-semibold uppercase tracking-wider text-mute">Security</h3>
                <p class="mt-4 text-sm text-body">
                  All calculations happen inside your browser. State is shared via compressed URL hashes. No data ever leaves your device.
                </p>
              </div>
            </div>
          </div>
        </div>
        <div class="mt-12 border-t border-hairline pt-8 flex items-center justify-between">
          <p class="text-xs text-mute">&copy; {new Date().getFullYear()} SplitWhat. All rights reserved.</p>
          <div class="flex gap-4">
            <a href="/" class="text-xs text-mute hover:text-ink font-mono">100% Client-Side</a>
            <span class="text-xs text-mute font-mono">•</span>
            <a href="/app" class="text-xs text-mute hover:text-ink font-mono">No Login Required</a>
          </div>
        </div>
      </div>
    </footer>
  </body>
</html>
