---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  keywords?: string;
  ogImage?: string;
}

const {
  title = 'SplitWhat — The No-Login Bill Splitter',
  description = 'Split What? Easily split bills, travel expenses, and subscription costs with friends. A free, client-side, no-login alternative to Splitwise. Completely offline-capable.',
  keywords = 'split bills, travel expense splitter, subscription bill splitter, splitwise alternative, no login bill splitter, free bill splitter',
  ogImage = '/og-image.png'
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site || 'https://splitwhat.vercel.app').toString();
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    
    <!-- Primary Meta Tags -->
    <title>{title}</title>
    <meta name="title" content={title} />
    <meta name="description" content={description} />
    <meta name="keywords" content={keywords} />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={canonicalURL} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={ogImage} />

    <!-- Preload fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;600&display=swap" rel="stylesheet" />

    <!-- inline script to prevent theme flashing -->
    <script is:inline>
      (function() {
        const theme = (() => {
          if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
            return localStorage.getItem('theme');
          }
          if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
            return 'dark';
          }
          return 'light';
        })();
      
        if (theme === 'dark') {
          document.documentElement.classList.add('dark');
        } else {
          document.documentElement.classList.remove('dark');
        }
        window.localStorage.setItem('theme', theme);
      })();
    </script>
  </head>
  <body class="flex flex-col min-h-screen bg-canvas-soft text-ink font-sans selection:bg-indigo-500 selection:text-white">
    <!-- Navbar -->
    <header class="sticky top-0 z-40 w-full border-b border-hairline bg-canvas/80 backdrop-blur-md">
      <div class="mx-auto flex h-16 max-w-7xl items-center justify-between px-4 sm:px-6 lg:px-8">
        <div class="flex items-center gap-6">
          <a href="/" class="flex items-center gap-2.5 text-xl font-bold tracking-tight hover:opacity-90">
            <svg class="h-6 w-6 shrink-0 transition-transform duration-500 ease-out hover:scale-110 hover:rotate-12" viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg">
              <defs>
                <filter id="header-glow" x="-20%" y="-20%" width="140%" height="140%">
                  <feDropShadow dx="0" dy="4" stdDeviation="4" flood-color="#4f46e5" flood-opacity="0.25" />
                </filter>
                <linearGradient id="header-grad-right" x1="0%" y1="0%" x2="100%" y2="100%">
                  <stop offset="0%" stop-color="#4f46e5" />
                  <stop offset="100%" stop-color="#06b6d4" />
                </linearGradient>
                <linearGradient id="header-grad-left" x1="0%" y1="100%" x2="100%" y2="0%">
                  <stop offset="0%" stop-color="#d946ef" />
                  <stop offset="100%" stop-color="#8b5cf6" />
                </linearGradient>
              </defs>
              <g transform="rotate(-45 50 50)" filter="url(#header-glow)">
                <path d="M53 12 A 35 35 0 0 1 53 82 A 6 6 0 0 1 53 70 A 23 23 0 0 0 53 24 A 6 6 0 0 1 53 12 Z" fill="url(#header-grad-right)" />
                <path d="M47 88 A 35 35 0 0 1 47 18 A 6 6 0 0 1 47 30 A 23 23 0 0 0 47 76 A 6 6 0 0 1 47 88 Z" fill="url(#header-grad-left)" />
              </g>
            </svg>
            <span>SplitWhat</span>
          </a>
          <nav class="hidden md:flex items-center gap-1">
            <a href="/" class="rounded-full px-3 py-1.5 text-sm font-medium text-body hover:bg-canvas-soft-2 hover:text-ink transition-colors">Features</a>
            <a href="/app" class="rounded-full px-3 py-1.5 text-sm font-medium text-body hover:bg-canvas-soft-2 hover:text-ink transition-colors font-mono">/app</a>
          </nav>
        </div>
        
        <div class="flex items-center gap-3">
          <!-- Sun/Moon Toggle Button -->
          <button 
            id="theme-toggle" 
            type="button" 
            class="inline-flex h-9 w-9 items-center justify-center rounded-full border border-hairline bg-canvas/50 text-body hover:bg-canvas-soft-2 hover:text-ink transition-all cursor-pointer focus:outline-none"
            aria-label="Toggle Dark Mode"
          >
            <!-- Sun Icon (visible in light mode, hidden in dark mode) -->
            <svg id="sun-icon" class="h-4.5 w-4.5 dark:hidden" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <circle cx="12" cy="12" r="5"></circle>
              <line x1="12" y1="1" x2="12" y2="3"></line>
              <line x1="12" y1="21" x2="12" y2="23"></line>
              <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line>
              <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line>
              <line x1="1" y1="12" x2="3" y2="12"></line>
              <line x1="21" y1="12" x2="23" y2="12"></line>
              <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line>
              <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line>
            </svg>
            <!-- Moon Icon (visible in dark mode, hidden in light mode) -->
            <svg id="moon-icon" class="h-4.5 w-4.5 hidden dark:block" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
            </svg>
          </button>

          <a 
            href="/app" 
            class="hidden sm:inline-flex h-9 items-center justify-center rounded-full bg-gradient-to-r from-indigo-500 to-violet-500 px-5 text-sm font-semibold text-white hover:opacity-95 transition-all shadow-md active:scale-95"
          >
            Launch App
          </a>

          <!-- Mobile Hamburger Toggle Button -->
          <button 
            id="mobile-menu-toggle"
            type="button"
            class="inline-flex md:hidden h-9 w-9 items-center justify-center rounded-full border border-hairline bg-canvas/50 text-body hover:bg-canvas-soft-2 hover:text-ink transition-all cursor-pointer focus:outline-none"
            aria-label="Toggle Navigation Menu"
          >
            <svg id="hamburger-icon" class="h-4.5 w-4.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <line x1="4" y1="6" x2="20" y2="6"></line>
              <line x1="4" y1="12" x2="20" y2="12"></line>
              <line x1="4" y1="18" x2="20" y2="18"></line>
            </svg>
            <svg id="close-icon" class="h-4.5 w-4.5 hidden" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <line x1="18" y1="6" x2="6" y2="18"></line>
              <line x1="6" y1="6" x2="18" y2="18"></line>
            </svg>
          </button>
        </div>
      </div>

      <!-- Mobile Dropdown Navigation Menu -->
      <div 
        id="mobile-menu" 
        class="hidden md:hidden border-t border-hairline bg-canvas/95 backdrop-blur-lg px-4 py-4 space-y-3 transition-all duration-200 ease-in-out origin-top scale-y-95 opacity-0"
      >
        <a 
          href="/" 
          class="block rounded-xl px-4 py-2.5 text-sm font-semibold text-body hover:bg-canvas-soft-2 hover:text-ink transition-all"
        >
          Features
        </a>
        <a 
          href="/app" 
          class="block rounded-xl px-4 py-2.5 text-sm font-semibold text-body hover:bg-canvas-soft-2 hover:text-ink transition-all font-mono"
        >
          /app
        </a>
        <div class="pt-2 border-t border-hairline sm:hidden">
          <a 
            href="/app" 
            class="flex w-full h-10 items-center justify-center rounded-full bg-gradient-to-r from-indigo-500 to-violet-500 px-5 text-sm font-semibold text-white hover:opacity-95 transition-all shadow-md active:scale-95"
          >
            Launch App
          </a>
        </div>
      </div>
    </header>

    <!-- Main Content -->
    <main class="flex-grow relative">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="border-t border-hairline bg-canvas">
      <div class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8 lg:py-16">
        <div class="xl:grid xl:grid-cols-3 xl:gap-8">
          <div class="space-y-4">
            <a href="/" class="flex items-center gap-2 text-lg font-bold tracking-tight">
              <svg class="h-5 w-5 shrink-0 transition-transform duration-500 ease-out hover:scale-110 hover:rotate-12" viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg">
                <defs>
                  <filter id="footer-glow" x="-20%" y="-20%" width="140%" height="140%">
                    <feDropShadow dx="0" dy="4" stdDeviation="4" flood-color="#4f46e5" flood-opacity="0.25" />
                  </filter>
                  <linearGradient id="footer-grad-right" x1="0%" y1="0%" x2="100%" y2="100%">
                    <stop offset="0%" stop-color="#4f46e5" />
                    <stop offset="100%" stop-color="#06b6d4" />
                  </linearGradient>
                  <linearGradient id="footer-grad-left" x1="0%" y1="100%" x2="100%" y2="0%">
                    <stop offset="0%" stop-color="#d946ef" />
                    <stop offset="100%" stop-color="#8b5cf6" />
                  </linearGradient>
                </defs>
                <g transform="rotate(-45 50 50)" filter="url(#footer-glow)">
                  <path d="M53 12 A 35 35 0 0 1 53 82 A 6 6 0 0 1 53 70 A 23 23 0 0 0 53 24 A 6 6 0 0 1 53 12 Z" fill="url(#footer-grad-right)" />
                  <path d="M47 88 A 35 35 0 0 1 47 18 A 6 6 0 0 1 47 30 A 23 23 0 0 0 47 76 A 6 6 0 0 1 47 88 Z" fill="url(#footer-grad-left)" />
                </g>
              </svg>
              <span>SplitWhat</span>
            </a>
            <p class="text-sm text-body max-w-xs">
              Local-first bill splitting for power users. Zero servers, zero tracking, 100% private.
            </p>
            <div class="font-mono text-xs text-mute">
              <span>MADE BY ADITYA SAINI</span>
            </div>
          </div>
          <div class="mt-12 grid grid-cols-2 gap-8 xl:col-span-2 xl:mt-0">
            <div class="md:grid md:grid-cols-2 md:gap-8">
              <div>
                <h3 class="font-mono text-xs font-semibold uppercase tracking-wider text-mute">Product</h3>
                <ul class="mt-4 space-y-2">
                  <li>
                    <a href="/app" class="text-sm text-body hover:text-ink">Launch Tool</a>
                  </li>
                  <li>
                    <a href="/" class="text-sm text-body hover:text-ink">Features</a>
                  </li>
                  <li>
                    <a href="/app?g=copy" class="text-sm text-body hover:text-ink font-mono text-[11px] text-mute hover:text-ink"></a>
                  </li>
                </ul>
              </div>
              <div class="mt-12 md:mt-0">
                <h3 class="font-mono text-xs font-semibold uppercase tracking-wider text-mute">Use Cases</h3>
                <ul class="mt-4 space-y-2">
                  <li>
                    <span class="text-sm text-body">Travel Splitting</span>
                  </li>
                  <li>
                    <span class="text-sm text-body">Subscription Sharing</span>
                  </li>
                  <li>
                    <span class="text-sm text-body">Roommate Expenses</span>
                  </li>
                </ul>
              </div>
            </div>
            <div class="md:grid md:grid-cols-1 md:gap-8">
              <div>
                <h3 class="font-mono text-xs font-semibold uppercase tracking-wider text-mute">Security</h3>
                <p class="mt-4 text-sm text-body">
                  Calculations run entirely in your browser. State is shared via compressed URL hashes, meaning absolutely no data ever leaves your device.
                </p>
              </div>
            </div>
          </div>
        </div>
        <div class="mt-12 border-t border-hairline pt-8 flex items-center justify-between">
          <p class="text-xs text-mute">&copy; {new Date().getFullYear()} SplitWhat. All rights reserved.</p>
          <div class="flex gap-4">
            <a href="/" class="text-xs text-mute hover:text-ink font-mono">100% Client-Side</a>
            <span class="text-xs text-mute font-mono">•</span>
            <a href="/app" class="text-xs text-mute hover:text-ink font-mono">No Login Required</a>
          </div>
        </div>
      </div>
    </footer>

    <!-- Theme Toggle & Mobile Menu Event Hooks -->
    <script is:inline>
      function setupThemeToggle() {
        const toggleBtn = document.getElementById('theme-toggle');
        if (!toggleBtn) return;
        toggleBtn.addEventListener('click', () => {
          document.documentElement.classList.add('theme-transition');
          const isDark = document.documentElement.classList.toggle('dark');
          localStorage.setItem('theme', isDark ? 'dark' : 'light');
          
          setTimeout(() => {
            document.documentElement.classList.remove('theme-transition');
          }, 350);
        });
      }

      function setupMobileMenu() {
        const toggleBtn = document.getElementById('mobile-menu-toggle');
        const mobileMenu = document.getElementById('mobile-menu');
        const hamburgerIcon = document.getElementById('hamburger-icon');
        const closeIcon = document.getElementById('close-icon');
        
        if (!toggleBtn || !mobileMenu) return;
        
        function toggleMenu() {
          const isHidden = mobileMenu.classList.contains('hidden');
          if (isHidden) {
            mobileMenu.classList.remove('hidden');
            requestAnimationFrame(() => {
              mobileMenu.classList.remove('scale-y-95', 'opacity-0');
              mobileMenu.classList.add('scale-y-100', 'opacity-100');
            });
            hamburgerIcon.classList.add('hidden');
            closeIcon.classList.remove('hidden');
          } else {
            mobileMenu.classList.remove('scale-y-100', 'opacity-100');
            mobileMenu.classList.add('scale-y-95', 'opacity-0');
            hamburgerIcon.classList.remove('hidden');
            closeIcon.classList.add('hidden');
            setTimeout(() => {
              if (mobileMenu.classList.contains('opacity-0')) {
                mobileMenu.classList.add('hidden');
              }
            }, 200);
          }
        }

        toggleBtn.addEventListener('click', (e) => {
          e.stopPropagation();
          toggleMenu();
        });

        // Close when clicking a link inside mobile-menu
        mobileMenu.querySelectorAll('a').forEach(link => {
          link.addEventListener('click', () => {
            if (!mobileMenu.classList.contains('hidden')) {
              toggleMenu();
            }
          });
        });

        // Close menu when clicking outside
        document.addEventListener('click', (e) => {
          if (!mobileMenu.classList.contains('hidden') && !mobileMenu.contains(e.target) && !toggleBtn.contains(e.target)) {
            toggleMenu();
          }
        });
      }
      
      function init() {
        setupThemeToggle();
        setupMobileMenu();
      }

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', init);
      } else {
        init();
      }
    </script>
  </body>
</html>
