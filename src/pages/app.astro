---
import Layout from '../layouts/Layout.astro';
---

<Layout title="SplitWhat App — Split Expenses Instantly" description="Frontend-only bill splitter. No signup required. Perfect for trip expenses and subscription splits.">
  <!-- Background Mesh Gradient -->
  <div class="mesh-gradient-bg"></div>

  <div class="mx-auto max-w-7xl px-4 py-8 sm:px-6 lg:px-8">
    
    <!-- Top Configuration Bar (Group Name, Currency, Mode) -->
    <div class="vercel-card p-6 mb-8">
      <div class="flex items-center gap-2 mb-4 text-xs font-semibold font-mono text-indigo-500 uppercase tracking-widest">
        <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"></path>
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
        </svg>
        <span>Group Settings</span>
      </div>

      <div class="grid grid-cols-1 gap-6 md:grid-cols-3 items-end">
        <!-- Group Name with Floating Label -->
        <div class="relative group">
          <span class="absolute left-3 top-3.5 text-mute">
            <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z"></path>
            </svg>
          </span>
          <input 
            type="text" 
            id="group-name" 
            value="My Trip"
            placeholder=" "
            class="peer w-full h-11 pl-10 pr-3 pt-3 rounded-xl border border-hairline bg-canvas text-ink font-sans text-sm focus:border-indigo-500 focus:ring-4 focus:ring-indigo-500/10 outline-none transition-all placeholder:opacity-0 vercel-input"
            maxlength="100"
          />
          <label 
            for="group-name" 
            class="absolute left-10 top-1.5 text-mute text-[9px] tracking-wider uppercase font-mono transition-all pointer-events-none origin-[0_0] peer-placeholder-shown:top-3.5 peer-placeholder-shown:text-sm peer-focus:top-1.5 peer-focus:text-[9px] peer-focus:text-indigo-500 font-semibold"
          >
            Group Name
          </label>
          <p class="text-[10px] text-mute mt-1.5">Includes in all PDF/QR exports</p>
        </div>

        <!-- Currency & Mode Toggle Row -->
        <div class="grid grid-cols-2 gap-4">
          <!-- Currency Selector -->
          <div>
            <label for="currency-selector" class="block font-mono text-[10px] font-semibold text-mute uppercase tracking-wider mb-2">Currency</label>
            <select 
              id="currency-selector" 
              class="w-full h-10 px-3 rounded-xl border border-hairline bg-canvas text-ink font-mono text-sm focus:border-indigo-500 focus:ring-4 focus:ring-indigo-500/10 outline-none transition-all cursor-pointer"
            >
              <option value="$">🇺🇸 USD ($)</option>
              <option value="€">🇪🇺 EUR (€)</option>
              <option value="£">🇬🇧 GBP (£)</option>
              <option value="₹">🇮🇳 INR (₹)</option>
              <option value="¥">🇯🇵 JPY (¥)</option>
              <option value="A$">🇦🇺 AUD (A$)</option>
              <option value="C$">🇨🇦 CAD (C$)</option>
              <option value="CHF">🇨🇭 CHF (CHF)</option>
              <option value="元">🇨🇳 CNY (元)</option>
              <option value="HK$">🇭🇰 HKD (HK$)</option>
              <option value="NZ$">🇳🇿 NZD (NZ$)</option>
              <option value="S$">🇸🇬 SGD (S$)</option>
              <option value="₩">🇰🇷 KRW (₩)</option>
              <option value="R$">🇧🇷 BRL (R$)</option>
              <option value="R">🇿🇦 ZAR (R)</option>
              <option value="Mex$">🇲🇽 MXN (Mex$)</option>
              <option value="AED">🇦🇪 AED (Dh)</option>
              <option value="kr">🇸🇪 SEK (kr)</option>
              <option value="kr">🇳🇴 NOK (kr)</option>
              <option value="kr">🇩🇰 DKK (kr)</option>
              <option value="₺">🇹🇷 TRY (₺)</option>
              <option value="₽">🇷🇺 RUB (₽)</option>
              <option value="₱">🇵🇭 PHP (₱)</option>
              <option value="RM">🇲🇾 MYR (RM)</option>
              <option value="Rp">🇮🇩 IDR (Rp)</option>
              <option value="฿">🇹🇭 THB (฿)</option>
              <option value="₫">🇻🇳 VND (₫)</option>
              <option value="zł">🇵🇱 PLN (zł)</option>
              <option value="SR">🇸🇦 SAR (SR)</option>
              <option value="₪">🇮🇱 ILS (₪)</option>
              <option value="Kč">🇨🇿 CZK (Kč)</option>
              <option value="Ft">🇭🇺 HUF (Ft)</option>
              <option value="lei">🇷🇴 RON (lei)</option>
              <option value="Kn">🇭🇷 HRK (kn)</option>
              <option value="din">🇷🇸 RSD (din)</option>
              <option value="lev">🇧🇬 BGN (lev)</option>
              <option value="₴">🇺🇦 UAH (₴)</option>
              <option value="₸">🇰🇿 KZT (₸)</option>
            </select>
          </div>

          <!-- Mode Toggle -->
          <div>
            <label class="block font-mono text-[10px] font-semibold text-mute uppercase tracking-wider mb-2">Split Mode</label>
            <div class="relative flex h-10 items-center justify-between rounded-xl border border-zinc-200 dark:border-zinc-800/60 bg-zinc-100 dark:bg-zinc-800/50 p-1">
              <button 
                type="button" 
                id="mode-travel-btn"
                class="z-10 w-1/2 text-center text-xs font-semibold py-1 rounded-lg transition-all text-zinc-950 dark:text-zinc-100 bg-white dark:bg-zinc-700 shadow-sm cursor-pointer"
              >
                Travel
              </button>
              <button 
                type="button" 
                id="mode-subscription-btn"
                class="z-10 w-1/2 text-center text-xs font-semibold py-1 rounded-lg transition-all text-zinc-500 hover:text-zinc-900 dark:text-zinc-400 dark:hover:text-zinc-100 cursor-pointer"
              >
                Sub
              </button>
            </div>
          </div>
        </div>

        <!-- Reset & Quick Load -->
        <div class="flex flex-wrap items-center justify-end gap-3 min-h-10">
          <select 
            id="recent-splits-selector" 
            class="hidden md:block h-10 px-3 rounded-xl border border-hairline bg-canvas text-body font-sans text-xs focus:border-indigo-500 focus:ring-4 focus:ring-indigo-500/10 outline-none max-w-[180px] transition-all cursor-pointer"
          >
            <option value="">Load Recent...</option>
          </select>
          <button 
            type="button" 
            id="reset-group-btn"
            class="inline-flex h-10 items-center justify-center rounded-xl border border-red-500 dark:border-red-400 bg-white dark:bg-zinc-900 text-red-600 dark:text-red-400 px-4 text-xs font-semibold hover:bg-red-50 dark:hover:bg-red-950/20 transition-all cursor-pointer active:scale-[0.98] shadow-sm"
          >
            Reset Group
          </button>
          <button 
            type="button" 
            id="clear-all-memory-btn"
            class="inline-flex h-10 items-center justify-center rounded-xl border border-red-500 dark:border-red-400 bg-white dark:bg-zinc-900 text-red-600 dark:text-red-400 px-4 text-xs font-semibold hover:bg-red-50 dark:hover:bg-red-950/20 transition-all cursor-pointer active:scale-[0.98] shadow-sm"
            title="Clear all stored splits, history, and current data from this device"
          >
            Clear All Memory
          </button>
        </div>
      </div>
    </div>

    <!-- Main Workspace Layout -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-start">
      
      <!-- LEFT COLUMN: Members & Expenses -->
      <div class="lg:col-span-7 space-y-8">
        
        <!-- Members List Card -->
        <div class="vercel-card p-6">
          <div class="flex items-center justify-between border-b border-hairline pb-4 mb-4">
            <div class="flex items-center gap-2">
              <svg class="h-5 w-5 text-indigo-500" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path>
              </svg>
              <div>
                <h2 class="text-lg font-semibold tracking-tight text-ink mb-1">Group Members</h2>
                <p class="text-sm text-zinc-500 dark:text-zinc-400">Add people who will split the bills.</p>
              </div>
            </div>
            <span id="members-count-badge" class="font-mono text-xs bg-zinc-100 dark:bg-zinc-800 px-2.5 py-0.5 rounded-full text-zinc-600 dark:text-zinc-400 font-medium">
              0 / 30
            </span>
          </div>

          <!-- Add Member Input (Inline Form) -->
          <form id="add-member-form" class="flex gap-3 mb-6 items-start">
            <div class="relative flex-grow">
              <span class="absolute left-3 top-3.5 text-mute">
                <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M18 9v3m0 0v3m0-3h3m-3 0h-3m-2-5a4 4 0 11-8 0 4 4 0 018 0zM3 20a6 6 0 0112 0v1H3v-1z"></path>
                </svg>
              </span>
              <input 
                type="text" 
                id="new-member-name" 
                placeholder=" " 
                class="peer w-full h-11 pl-10 pr-3 pt-3 rounded-xl border border-hairline bg-canvas text-ink font-sans text-sm focus:border-indigo-500 focus:ring-4 focus:ring-indigo-500/10 outline-none transition-all placeholder:opacity-0 vercel-input"
                maxlength="50"
              />
              <label 
                for="new-member-name" 
                class="absolute left-10 top-1.5 text-mute text-[9px] tracking-wider uppercase font-mono transition-all pointer-events-none origin-[0_0] peer-placeholder-shown:top-3.5 peer-placeholder-shown:text-sm peer-focus:top-1.5 peer-focus:text-[9px] peer-focus:text-indigo-500 font-semibold"
              >
                Member Name
              </label>
              <span id="member-validation-error" class="hidden absolute left-0 -bottom-5 text-[10px] text-error font-sans"></span>
            </div>
            <button 
              type="submit" 
              class="inline-flex h-11 items-center justify-center rounded-xl bg-indigo-600 px-6 text-sm font-semibold text-white shadow-lg shadow-indigo-600/20 hover:bg-indigo-700 active:scale-[0.98] transition-all cursor-pointer"
            >
              Add
            </button>
          </form>

          <!-- Members Chips Container -->
          <div id="members-list-container" class="flex flex-wrap gap-2.5 mt-6 min-h-[40px] items-center">
            <!-- Dynamic Member Chips -->
            <div id="empty-members-placeholder" class="py-6 text-center flex flex-col items-center justify-center text-mute space-y-2 w-full">
              <svg class="h-10 w-10 text-zinc-300 dark:text-zinc-700" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M18 18.72a9.094 9.094 0 003.741-.479 3 3 0 00-4.682-2.72m.94 3.198l.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0112 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 016 18.719m12 0a5.971 5.971 0 00-.941-3.197m0 0A5.995 5.995 0 0012 12.75a5.995 5.995 0 00-5.058 2.772m0 0a3 3 0 00-4.681 2.72 8.986 8.986 0 003.74.477m.94-3.197a5.971 5.971 0 00-.94 3.197M15 6.75a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
              <span class="text-xs font-semibold text-ink">No members added yet</span>
              <span class="text-[10px] text-mute max-w-xs">Add at least two people to start splitting expenses.</span>
            </div>
          </div>
        </div>

        <!-- Add Expense Form Container (Acts as Bottom Sheet on Mobile) -->
        <div id="add-expense-card-container" class="fixed inset-x-0 bottom-0 z-50 rounded-t-3xl bg-canvas p-6 shadow-2xl transform translate-y-full transition-transform duration-300 md:relative md:inset-auto md:translate-y-0 md:rounded-2xl md:shadow-none md:z-auto md:bg-transparent md:p-0">
          
          <div class="vercel-card p-6 h-full md:h-auto overflow-y-auto max-h-[85vh] md:max-h-none">
            <!-- Drag indicator / Close handle for Mobile Sheet -->
            <div class="flex flex-col items-center pb-4 md:hidden">
              <div class="w-12 h-1.5 bg-zinc-300 dark:bg-zinc-700 rounded-full mb-3"></div>
              <div class="flex justify-between items-center w-full">
                <span class="text-sm font-bold text-ink">Add Expense</span>
                <button 
                  id="close-mobile-sheet-btn" 
                  type="button" 
                  class="text-mute hover:text-ink font-semibold text-lg p-1"
                >
                  ✕
                </button>
              </div>
            </div>

            <div class="flex items-center gap-2 border-b border-hairline pb-4 mb-6">
              <svg class="h-5 w-5 text-indigo-500" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"></path>
              </svg>
              <div>
                <h2 class="text-lg font-semibold tracking-tight text-ink mb-1">Add Expense</h2>
                <p class="text-sm text-zinc-500 dark:text-zinc-400">Enter expense item details below.</p>
              </div>
            </div>

            <div id="expense-form-error-summary" class="hidden rounded-xl bg-error-soft/30 border border-error/20 text-error-deep p-3 text-xs mb-4">
              Please correct the validation errors below.
            </div>

            <form id="add-expense-form" class="space-y-5">
              <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
                <!-- Title with Floating Label -->
                <div class="relative group">
                  <span class="absolute left-3 top-3.5 text-mute">
                    <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M7 7h.01M6 20a1 1 0 02-1-1v-4.586a1 1 0 01.293-.707l7-7a1 1 0 011.414 0l4.586 4.586a1 1 0 010 1.414l-7 7a1 1 0 01-.707.293H6z"></path>
                    </svg>
                  </span>
                  <input 
                    type="text" 
                    id="expense-title" 
                    placeholder=" "
                    class="peer w-full h-11 pl-10 pr-3 pt-3 rounded-xl border border-hairline bg-canvas text-ink font-sans text-sm focus:border-indigo-500 focus:ring-4 focus:ring-indigo-500/10 outline-none transition-all placeholder:opacity-0 vercel-input"
                    maxlength="100"
                  />
                  <label 
                    for="expense-title" 
                    class="absolute left-10 top-1.5 text-mute text-[9px] tracking-wider uppercase font-mono transition-all pointer-events-none origin-[0_0] peer-placeholder-shown:top-3.5 peer-placeholder-shown:text-sm peer-focus:top-1.5 peer-focus:text-[9px] peer-focus:text-indigo-500 font-semibold"
                  >
                    Expense Title
                  </label>
                  <span id="err-expense-title" class="hidden text-[10px] text-error mt-1.5 block"></span>
                  <p class="text-[10px] text-mute mt-1.5">e.g. Flights, Pizza, Rent</p>
                </div>

                <!-- Category & Streaming Provider -->
                <div class="space-y-3">
                  <div>
                    <label for="expense-category" class="block font-mono text-[10px] font-semibold text-mute uppercase tracking-wider mb-2">Category</label>
                    <select 
                      id="expense-category" 
                      class="w-full h-11 px-3 rounded-xl border border-hairline bg-canvas text-ink font-sans text-sm focus:border-indigo-500 focus:ring-4 focus:ring-indigo-500/10 outline-none transition-all cursor-pointer"
                    >
                      <!-- Dynamically populated categories -->
                    </select>
                  </div>
                  <!-- Streaming Provider selector (only shown when Streaming category is selected) -->
                  <div id="streaming-service-container" class="hidden animate-fade-in">
                    <label for="streaming-service" class="block font-mono text-[10px] font-semibold text-mute uppercase tracking-wider mb-2">Streaming Provider</label>
                    <select 
                      id="streaming-service" 
                      class="w-full h-11 px-3 rounded-xl border border-hairline bg-canvas text-ink font-sans text-sm focus:border-indigo-500 focus:ring-4 focus:ring-indigo-500/10 outline-none transition-all cursor-pointer"
                    >
                      <option value="netflix">Netflix 🍿</option>
                      <option value="prime">Amazon Prime Video 📦</option>
                      <option value="disney">Disney+ 🏰</option>
                      <option value="hulu">Hulu 🟢</option>
                      <option value="hbo">Max (HBO) 🟣</option>
                      <option value="apple">Apple TV+ 🍎</option>
                      <option value="peacock">Peacock 🦚</option>
                      <option value="paramount">Paramount+ 🏔️</option>
                      <option value="youtube">YouTube Premium 🔴</option>
                      <option value="crunchyroll">Crunchyroll 🍥</option>
                      <option value="other">Other Streaming 📺</option>
                    </select>
                  </div>
                </div>
              </div>

              <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
                <!-- Amount with Floating Label -->
                <div class="relative">
                  <span id="expense-amount-symbol" class="absolute left-3 top-3 text-mute font-mono text-sm font-semibold">$</span>
                  <input 
                    type="number" 
                    id="expense-amount" 
                    step="0.01" 
                    min="0.01"
                    placeholder=" "
                    class="peer w-full h-11 pl-8 pr-3 pt-3 rounded-xl border border-hairline bg-canvas text-ink font-sans text-sm focus:border-indigo-500 focus:ring-4 focus:ring-indigo-500/10 outline-none transition-all placeholder:opacity-0 vercel-input font-mono"
                  />
                  <label 
                    for="expense-amount" 
                    class="absolute left-8 top-1.5 text-mute text-[9px] tracking-wider uppercase font-mono transition-all pointer-events-none origin-[0_0] peer-placeholder-shown:top-3.5 peer-placeholder-shown:text-sm peer-focus:top-1.5 peer-focus:text-[9px] peer-focus:text-indigo-500 font-semibold"
                  >
                    Amount Paid
                  </label>
                  <span id="err-expense-amount" class="hidden text-[10px] text-error mt-1.5 block"></span>
                  <p class="text-[10px] text-mute mt-1.5">Enter the total amount paid</p>
                </div>

                <!-- Paid By -->
                <div>
                  <label for="expense-paid-by" class="block font-mono text-[10px] font-semibold text-mute uppercase tracking-wider mb-2">Paid By</label>
                  <select 
                    id="expense-paid-by" 
                    class="w-full h-11 px-3 rounded-xl border border-hairline bg-canvas text-ink font-sans text-sm focus:border-indigo-500 focus:ring-4 focus:ring-indigo-500/10 outline-none transition-all cursor-pointer"
                  >
                    <option value="">Choose member...</option>
                  </select>
                  <span id="err-expense-paid-by" class="hidden text-[10px] text-error mt-1.5 block"></span>
                </div>
              </div>

              <!-- Split Among Checkboxes -->
              <div class="space-y-3">
                <div class="flex items-center justify-between">
                  <span class="block font-mono text-[10px] font-semibold text-mute uppercase tracking-wider">Split Among</span>
                  <!-- Split Type Selector -->
                  <div class="inline-flex rounded-xl bg-zinc-100 dark:bg-zinc-800/50 p-1 border border-hairline" id="split-type-toggle-container">
                    <button 
                      type="button" 
                      id="split-type-equal-btn"
                      class="text-[10px] font-bold py-1 px-2.5 rounded-lg transition-all bg-white dark:bg-zinc-700 text-zinc-950 dark:text-zinc-100 shadow-sm cursor-pointer"
                    >
                      Equally
                    </button>
                    <button 
                      type="button" 
                      id="split-type-unequal-btn"
                      class="text-[10px] font-bold py-1 px-2.5 rounded-lg transition-all text-zinc-500 hover:text-zinc-950 dark:text-zinc-400 cursor-pointer"
                    >
                      Unequally
                    </button>
                  </div>
                </div>

                <div class="flex items-center justify-between text-[11px] text-mute">
                  <span>Select who to split with:</span>
                  <div class="flex gap-2">
                    <button type="button" id="split-select-all" class="text-xs text-indigo-500 hover:text-indigo-600 font-semibold transition-colors cursor-pointer">Select All</button>
                    <span class="text-xs text-mute font-mono">•</span>
                    <button type="button" id="split-deselect-all" class="text-xs text-indigo-500 hover:text-indigo-600 font-semibold transition-colors cursor-pointer">Deselect All</button>
                  </div>
                </div>

                <div id="split-members-checkboxes" class="flex flex-col gap-2 p-3 rounded-xl border border-hairline bg-canvas-soft-2 max-h-[220px] overflow-y-auto">
                  <!-- Checkboxes populated dynamically -->
                  <p id="split-empty-placeholder" class="col-span-full text-xs text-mute italic text-center py-2">Add group members to split with.</p>
                </div>
                <span id="unequal-status-text" class="hidden text-xs font-semibold mt-1.5 block"></span>
                <span id="err-expense-split-among" class="hidden text-[10px] text-error mt-1.5 block"></span>
              </div>

              <!-- Submit Button -->
              <button 
                type="submit" 
                class="w-full inline-flex h-11 items-center justify-center rounded-xl bg-gradient-to-r from-indigo-500 to-violet-500 px-5 text-sm font-semibold text-white shadow-lg shadow-indigo-500/25 hover:shadow-xl hover:shadow-indigo-500/30 hover:scale-[1.02] active:scale-[0.98] transition-all duration-200 cursor-pointer"
              >
                Log Expense
              </button>
            </form>
          </div>
        </div>

        <!-- Logged Expenses List Card -->
        <div class="vercel-card p-6">
          <div class="flex items-center justify-between border-b border-hairline pb-4 mb-4">
            <div class="flex items-center gap-2">
              <svg class="h-5 w-5 text-indigo-500" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
