  // Count up value animator
  function animateValue(obj: HTMLElement, start: number, end: number, duration: number) {
    if (totalSpendAnimFrameId !== null) {
      cancelAnimationFrame(totalSpendAnimFrameId);
    }
    
    let startTimestamp: number | null = null;
    const step = (timestamp: number) => {
      if (!startTimestamp) startTimestamp = timestamp;
      const progress = Math.min((timestamp - startTimestamp) / duration, 1);
      const currentValue = start + progress * (end - start);
      obj.innerHTML = state.currency + currentValue.toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 2 });
      if (progress < 1) {
        totalSpendAnimFrameId = window.requestAnimationFrame(step);
      } else {
        totalSpendAnimFrameId = null;
      }
    };
    totalSpendAnimFrameId = window.requestAnimationFrame(step);
  }

  // Toast notifications
  function showToast(message: string, type: 'info' | 'error' = 'info') {
    const toast = document.createElement('div');
    toast.className = `pointer-events-auto flex items-center justify-between rounded-xl bg-canvas border ${type === 'error' ? 'border-error text-error-deep' : 'border-hairline text-ink'} px-4 py-3 shadow-lg min-w-[280px] transition-all duration-300 opacity-0 translate-y-2`;
    toast.innerHTML = `
      <span class="text-xs font-semibold">${message}</span>
      <button class="text-mute hover:text-ink text-xs font-mono ml-4 cursor-pointer" onclick="this.parentElement.remove()">✕</button>
    `;
    elements.toastContainer.appendChild(toast);
    
    setTimeout(() => {
      toast.classList.remove('opacity-0', 'translate-y-2');
      toast.classList.add('opacity-100', 'translate-y-0');
    }, 10);
    
    setTimeout(() => {
      if (toast.parentElement) {
        toast.classList.remove('opacity-100', 'translate-y-0');
        toast.classList.add('opacity-0', 'translate-y-2');
        setTimeout(() => toast.remove(), 300);
      }
    }, 4000);
  }

  // Undo Toast Notifications
  function showUndoToast(message: string) {
    const toast = document.createElement('div');
    toast.className = `pointer-events-auto flex items-center justify-between rounded-xl bg-canvas border border-hairline text-ink px-4 py-3 shadow-lg min-w-[320px] transition-all duration-300 opacity-0 translate-y-2`;
    toast.innerHTML = `
      <div class="flex flex-col gap-0.5">
        <span class="text-xs font-semibold">${message}</span>
        <span class="text-[10px] text-mute">You can undo this action.</span>
      </div>
      <div class="flex items-center gap-3 ml-4">
        <button id="undo-delete-btn" class="text-xs font-bold text-indigo-500 hover:text-indigo-600 transition-colors uppercase tracking-wider cursor-pointer">Undo</button>
        <button class="text-mute hover:text-ink text-xs font-mono cursor-pointer" onclick="this.parentElement.parentElement.remove()">✕</button>
      </div>
    `;
    elements.toastContainer.appendChild(toast);
    
    const undoBtn = toast.querySelector('#undo-delete-btn')!;
    undoBtn.addEventListener('click', () => {
      if (lastDeletedExpense) {
        state.expenses.push(lastDeletedExpense);
        saveCurrentGroup(state);
        populateRecentsDropdown();
        renderAll();
        showToast(`Restored expense "${lastDeletedExpense.title}".`);
        toast.remove();
        lastDeletedExpense = null;
      }
    });
    
    setTimeout(() => {
      toast.classList.remove('opacity-0', 'translate-y-2');
      toast.classList.add('opacity-100', 'translate-y-0');
    }, 10);
    
    setTimeout(() => {
      if (toast.parentElement) {
        toast.classList.remove('opacity-100', 'translate-y-0');
        toast.classList.add('opacity-0', 'translate-y-2');
        setTimeout(() => toast.remove(), 300);
      }
    }, 6000);
  }

  // Load state and run updates
  function init() {
    const params = new URLSearchParams(window.location.search);
    const hasShareParam = params.has('g');
    
    if (hasShareParam) {
      const urlState = decodeStateFromUrl(window.location.href);
      if (urlState) {
        state = urlState;
        isReadOnly = true;
        
        // Lock UI controls to read-only mode
        if (elements.groupName) elements.groupName.disabled = true;
        if (elements.currencySelector) elements.currencySelector.disabled = true;
        if (elements.modeTravelBtn) elements.modeTravelBtn.classList.add('pointer-events-none', 'opacity-50');
        if (elements.modeSubscriptionBtn) elements.modeSubscriptionBtn.classList.add('pointer-events-none', 'opacity-50');
        
        if (elements.resetGroupBtn) elements.resetGroupBtn.classList.add('hidden');
        if (elements.clearAllMemoryBtn) elements.clearAllMemoryBtn.classList.add('hidden');
        if (elements.addMemberForm) elements.addMemberForm.classList.add('hidden');
        if (elements.addExpenseCardContainer) elements.addExpenseCardContainer.classList.add('hidden');
        if (elements.mobileAddExpenseFab) elements.mobileAddExpenseFab.classList.add('hidden');
        
        showToast('Viewing shared read-only group split.');
      } else {
        showToast('Failed to load group from link. Starting clean...', 'error');
        loadDefaultState();
      }
    } else {
      const localState = loadCurrentGroup();
      if (localState) {
        state = localState;
      } else {
        loadDefaultState();
      }
    }

    elements.groupName.value = state.name;
    elements.currencySelector.value = state.currency;
    elements.expenseAmountSymbol.textContent = state.currency;
    updateModeUI(state.mode);
    populateCategories();
    populateRecentsDropdown();
    
    // Bind Mobile Specific sheet handlers
    if (elements.mobileAddExpenseFab) {
      elements.mobileAddExpenseFab.addEventListener('click', openMobileSheet);
    }
    if (elements.closeMobileSheetBtn) {
      elements.closeMobileSheetBtn.addEventListener('click', closeMobileSheet);
    }
    if (elements.mobileSheetBackdrop) {
      elements.mobileSheetBackdrop.addEventListener('click', closeMobileSheet);
    }

    renderAll();

    const pendingToast = sessionStorage.getItem('toast_message');
    if (pendingToast) {
      showToast(pendingToast);
      sessionStorage.removeItem('toast_message');
    }
  }

  function loadDefaultState() {
    state = {
      id: Math.random().toString(36).substring(2, 9),
      name: 'My Trip',
      currency: '$',
      members: [
        { id: 'm1', name: 'Alex' },
        { id: 'm2', name: 'Sam' },
        { id: 'm3', name: 'Jo' }
      ],
      expenses: [],
      mode: 'travel',
    };
    saveCurrentGroup(state);
  }

  function openMobileSheet() {
    elements.mobileSheetBackdrop.classList.remove('hidden');
    setTimeout(() => {
      elements.mobileSheetBackdrop.classList.remove('opacity-0');
      elements.addExpenseCardContainer.classList.remove('translate-y-full');
      elements.addExpenseCardContainer.classList.add('translate-y-0');
    }, 10);
  }

  function closeMobileSheet() {
    elements.addExpenseCardContainer.classList.remove('translate-y-0');
    elements.addExpenseCardContainer.classList.add('translate-y-full');
    elements.mobileSheetBackdrop.classList.add('opacity-0');
    setTimeout(() => {
      elements.mobileSheetBackdrop.classList.add('hidden');
    }, 300);
  }

  function populateRecentsDropdown() {
    const recents = loadRecents();
    elements.recentSplitsSelector.innerHTML = '<option value="">Load Recent...</option>';
    
    if (recents.length === 0) {
      elements.recentSplitsSelector.classList.add('hidden');
      return;
    }
    
    elements.recentSplitsSelector.classList.remove('hidden');
    
    for (const r of recents) {
      const option = document.createElement('option');
      option.value = r.id;
      option.textContent = `${r.name || 'Untitled'} (${r.members.length} members)`;
      elements.recentSplitsSelector.appendChild(option);
    }
  }

  function updateModeUI(mode: 'travel' | 'subscription') {
    state.mode = mode;
    if (mode === 'travel') {
      elements.modeTravelBtn.className = "z-10 w-1/2 text-center text-xs font-semibold py-1 rounded-lg transition-all text-zinc-950 dark:text-zinc-100 bg-white dark:bg-zinc-700 shadow-sm cursor-pointer";
      elements.modeSubscriptionBtn.className = "z-10 w-1/2 text-center text-xs font-semibold py-1 rounded-lg transition-all text-zinc-500 hover:text-zinc-900 dark:text-zinc-400 dark:hover:text-zinc-100 cursor-pointer";
    } else {
      elements.modeSubscriptionBtn.className = "z-10 w-1/2 text-center text-xs font-semibold py-1 rounded-lg transition-all text-zinc-950 dark:text-zinc-100 bg-white dark:bg-zinc-700 shadow-sm cursor-pointer";
      elements.modeTravelBtn.className = "z-10 w-1/2 text-center text-xs font-semibold py-1 rounded-lg transition-all text-zinc-500 hover:text-zinc-900 dark:text-zinc-400 dark:hover:text-zinc-100 cursor-pointer";
    }
  }

  function populateCategories() {
    const categories = state.mode === 'travel' ? TRAVEL_CATEGORIES : SUBSCRIPTION_CATEGORIES;
    elements.expenseCategory.innerHTML = '';
    for (const category of categories) {
      const opt = document.createElement('option');
      opt.value = category;
      opt.textContent = category.charAt(0).toUpperCase() + category.slice(1);
      elements.expenseCategory.appendChild(opt);
    }
    toggleStreamingServiceVisibility();
  }

  function toggleStreamingServiceVisibility() {
    if (state.mode === 'subscription' && elements.expenseCategory.value === 'streaming') {
      elements.streamingServiceContainer.classList.remove('hidden');
    } else {
      elements.streamingServiceContainer.classList.add('hidden');
    }
  }

  // Render Functions
  function renderAll() {
    renderMembers();
    renderExpenses();
    renderCalculations();
    renderShareActions();
  }

  function renderMembers() {
    elements.membersCountBadge.textContent = `${state.members.length} / ${LIMITS.MAX_MEMBERS}`;
    elements.membersListContainer.innerHTML = '';
    
    if (state.members.length === 0) {
      elements.membersListContainer.appendChild(elements.emptyMembersPlaceholder);
    } else {
      for (const m of state.members) {
        const colors = getAvatarColor(m.name);
        const chip = document.createElement('div');
        chip.className = `inline-flex items-center gap-1.5 rounded-full border px-3 py-1.5 text-sm font-medium shadow-sm transition-all duration-200 hover:scale-102 ${colors.bg} animate-fade-in`;
        
        const avatar = document.createElement('span');
        avatar.className = `flex h-5 w-5 shrink-0 items-center justify-center rounded-full text-[10px] font-bold uppercase tracking-wider ${colors.avatar}`;
        avatar.textContent = m.name.charAt(0);
        chip.appendChild(avatar);

        const nameSpan = document.createElement('span');
        nameSpan.textContent = m.name;
        chip.appendChild(nameSpan);
        
        if (!isReadOnly) {
          const removeBtn = document.createElement('button');
          removeBtn.type = 'button';
          removeBtn.className = 'text-mute hover:text-error transition-colors ml-1 font-bold text-xs p-0.5 cursor-pointer';
          removeBtn.textContent = '×';
          removeBtn.setAttribute('aria-label', `Remove ${m.name}`);
          
          removeBtn.addEventListener('click', () => {
            chip.classList.add('scale-90', 'opacity-0');
            setTimeout(() => {
              removeMember(m.id);
            }, 200);
          });
          chip.appendChild(removeBtn);
        }
        
        elements.membersListContainer.appendChild(chip);
      }
    }

    updatePaidByDropdown();
    updateSplitAmongCheckboxes();
  }

  function updatePaidByDropdown() {
    const currentValue = elements.expensePaidBy.value;
    elements.expensePaidBy.innerHTML = '<option value="">Choose member...</option>';
    
    for (const m of state.members) {
      const opt = document.createElement('option');
      opt.value = m.id;
      opt.textContent = m.name;
      elements.expensePaidBy.appendChild(opt);
    }
    
    if (state.members.some(m => m.id === currentValue)) {
      elements.expensePaidBy.value = currentValue;
    }
  }

  function updateUnequalSplitStatus() {
    if (currentSplitType !== 'unequal') {
      elements.unequalStatusText.classList.add('hidden');
      return;
    }

    elements.unequalStatusText.classList.remove('hidden');
    const totalAmount = parseFloat(elements.expenseAmount.value) || 0;
    
    let sum = 0;
    const inputs = elements.splitMembersCheckboxes.querySelectorAll('input[type="number"]');
    inputs.forEach((input: any) => {
      const parentRow = input.closest('.split-member-row');
      const checkbox = parentRow ? parentRow.querySelector('input[type="checkbox"]') : null;
      if (checkbox && checkbox.checked) {
        sum += parseFloat(input.value) || 0;
      }
    });

    const difference = totalAmount - sum;
    if (Math.abs(difference) < 0.01) {
      elements.unequalStatusText.className = 'text-xs text-emerald-500 font-semibold mt-1.5 block';
      elements.unequalStatusText.textContent = `Sum matches total! 🎉`;
    } else if (difference > 0) {
      elements.unequalStatusText.className = 'text-xs text-amber-500 font-semibold mt-1.5 block';
      elements.unequalStatusText.textContent = `Sum is short by ${state.currency}${difference.toFixed(2)}`;
    } else {
      elements.unequalStatusText.className = 'text-xs text-error font-semibold mt-1.5 block';
      elements.unequalStatusText.textContent = `Sum exceeds total by ${state.currency}${Math.abs(difference).toFixed(2)}`;
    }
  }

  function updateSplitAmongCheckboxes() {
    const checkedValues = new Set<string>();
    const shareValues: Record<string, string> = {};
    
    const rows = elements.splitMembersCheckboxes.querySelectorAll('.split-member-row');
    rows.forEach((row: any) => {
      const cb = row.querySelector('input[type="checkbox"]');
      const numInput = row.querySelector('input[type="number"]');
      if (cb && cb.checked) {
        checkedValues.add(cb.value);
        if (numInput) {
          shareValues[cb.value] = numInput.value;
        }
      }
    });

    elements.splitMembersCheckboxes.innerHTML = '';

    if (state.members.length === 0) {
      elements.splitMembersCheckboxes.appendChild(elements.splitEmptyPlaceholder);
      return;
    }

    for (const m of state.members) {
      const row = document.createElement('div');
      row.className = 'split-member-row flex items-center justify-between p-2 rounded-xl bg-canvas border border-hairline/40 transition-colors hover:bg-canvas-soft-2/50 w-full';
      
      const label = document.createElement('label');
      label.className = 'flex items-center gap-2 text-xs text-ink cursor-pointer select-none py-1 flex-grow';
      
      const cb = document.createElement('input');
      cb.type = 'checkbox';
      cb.value = m.id;
      cb.name = 'split-member';
      cb.checked = checkedValues.size === 0 ? true : checkedValues.has(m.id);
      cb.className = 'rounded border-hairline-strong text-primary focus:ring-primary h-4 w-4 cursor-pointer';
      
      const span = document.createElement('span');
      span.textContent = m.name;
      
      label.appendChild(cb);
      label.appendChild(span);
      row.appendChild(label);
      
      // Share input container
      const inputContainer = document.createElement('div');
      inputContainer.className = `relative w-24 ml-2 transition-all duration-200 ${currentSplitType === 'unequal' ? '' : 'hidden'}`;
      
      const symbolSpan = document.createElement('span');
      symbolSpan.className = 'absolute left-2.5 top-1.5 text-mute text-[10px] font-mono';
      symbolSpan.textContent = state.currency;
      
      const numInput = document.createElement('input');
      numInput.type = 'number';
      numInput.step = '0.01';
      numInput.min = '0';
      numInput.placeholder = '0.00';
      numInput.value = shareValues[m.id] || '';
      numInput.className = 'w-full h-7 pl-5 pr-2 rounded-lg border border-hairline bg-canvas text-ink text-xs font-mono outline-none focus:border-indigo-500 text-right';
      
      // Handle disabling input if checkbox is unchecked
      if (!cb.checked) {
        numInput.disabled = true;
        numInput.classList.add('opacity-40');
      }

      cb.addEventListener('change', () => {
        if (cb.checked) {
          numInput.disabled = false;
          numInput.classList.remove('opacity-40');
        } else {
          numInput.disabled = true;
          numInput.classList.add('opacity-40');
          numInput.value = '';
        }
        updateUnequalSplitStatus();
      });

      numInput.addEventListener('input', updateUnequalSplitStatus);

      inputContainer.appendChild(symbolSpan);
      inputContainer.appendChild(numInput);
      row.appendChild(inputContainer);

      elements.splitMembersCheckboxes.appendChild(row);
    }
  }

  function renderExpenses() {
    elements.expensesCountBadge.textContent = `${state.expenses.length} / ${LIMITS.MAX_EXPENSES}`;
    elements.expensesListContainer.innerHTML = '';
    
    if (state.expenses.length === 0) {
      elements.expensesListContainer.appendChild(elements.emptyExpensesPlaceholder);
      return;
    }

    const sortedExpenses = [...state.expenses].reverse();

    for (const exp of sortedExpenses) {
      const payerName = state.members.find(m => m.id === exp.paidBy)?.name || 'Deleted Member';
      
      const container = document.createElement('div');
      container.className = 'w-full border-b border-hairline last:border-b-0 group/exp animate-fade-in relative';
      
      // Main content block
      const mainContent = document.createElement('div');
      mainContent.className = 'w-full py-4 px-3 flex items-center justify-between gap-4 hover:bg-canvas-soft/40 dark:hover:bg-canvas-soft/10 rounded-xl transition-all cursor-pointer select-none';
      
      // Left part: Category Icon + Description details
      const leftPart = document.createElement('div');
      leftPart.className = 'flex items-center gap-3.5 min-w-0';
      
      const iconContainer = document.createElement('div');
      iconContainer.className = 'flex h-10 w-10 shrink-0 items-center justify-center rounded-xl bg-indigo-500/10 text-indigo-500 dark:bg-indigo-500/20 border border-indigo-500/10';
      iconContainer.innerHTML = getCategoryIcon(exp.subCategory || exp.category);
      
      const textDetails = document.createElement('div');
      textDetails.className = 'flex flex-col min-w-0';
      
      const titleSpan = document.createElement('span');
      titleSpan.className = 'text-sm font-semibold text-ink truncate max-w-[180px] sm:max-w-[300px]';
      titleSpan.textContent = exp.title;
      
      const subText = document.createElement('div');
      subText.className = 'flex flex-wrap items-center gap-1.5 text-xs text-mute mt-1';
      
      const catText = exp.subCategory ? `${exp.category} (${exp.subCategory})` : exp.category;
      subText.innerHTML = `<span class="inline-flex items-center rounded-full bg-canvas-soft-2 border border-hairline px-2 py-0.5 text-[10px] font-semibold text-body capitalize">${catText}</span> <span>Paid by <strong class="text-body font-semibold">${payerName}</strong></span> <span class="text-[9px]">•</span> <span>Split with ${exp.splitAmong.length} ${exp.splitAmong.length === 1 ? 'person' : 'people'}</span>`;
      
      textDetails.appendChild(titleSpan);
      textDetails.appendChild(subText);
      
      leftPart.appendChild(iconContainer);
      leftPart.appendChild(textDetails);
      
      // Right part: amount and chevron
      const rightPart = document.createElement('div');
      rightPart.className = 'flex items-center gap-3 flex-shrink-0';
      
      const amountSpan = document.createElement('span');
      amountSpan.className = 'text-sm font-bold text-ink font-mono tabular-nums';
      amountSpan.textContent = `${state.currency}${exp.amount.toFixed(2)}`;
      
      const chevron = document.createElement('div');
      chevron.className = 'text-mute transition-transform duration-200 transform';
      chevron.innerHTML = `<svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>`;
      
      rightPart.appendChild(amountSpan);
      rightPart.appendChild(chevron);
      
      mainContent.appendChild(leftPart);
      mainContent.appendChild(rightPart);
      
      // Details panel
      const detailsPanel = document.createElement('div');
      detailsPanel.className = 'hidden px-4 pb-4 pt-3 border-t border-hairline bg-canvas-soft-2/10 dark:bg-zinc-950/20 rounded-b-xl space-y-4 animate-fade-in';
      
      const isUnequal = exp.shares && Object.keys(exp.shares).length > 0;
      
      const breakdownTitle = document.createElement('div');
      breakdownTitle.className = 'flex items-center justify-between border-b border-hairline pb-2';
      breakdownTitle.innerHTML = `
        <span class="text-[9px] font-bold font-mono text-mute uppercase tracking-widest">Split Breakdown ${isUnequal ? '(Unequal)' : '(Equal)'}</span>
        <span class="text-[9px] font-bold font-mono text-mute uppercase tracking-widest">${isUnequal ? 'Custom Share' : `Share (${state.currency}${(exp.amount / exp.splitAmong.length).toFixed(2)}/ea)`}</span>
      `;
      detailsPanel.appendChild(breakdownTitle);
      
      const breakdownList = document.createElement('div');
      breakdownList.className = 'grid grid-cols-1 sm:grid-cols-2 gap-2';
      
      for (const mId of exp.splitAmong) {
        const mName = state.members.find(m => m.id === mId)?.name || 'Unknown';
        const colors = getAvatarColor(mName);
        const personShare = (exp.shares && typeof exp.shares[mId] === 'number')
          ? exp.shares[mId]
          : exp.amount / exp.splitAmong.length;
        
        const itemCard = document.createElement('div');
        itemCard.className = 'flex items-center gap-2 bg-canvas border border-hairline p-2.5 rounded-xl text-xs shadow-sm hover:border-hairline-strong transition-all';
        itemCard.innerHTML = `
          <span class="flex h-5 w-5 shrink-0 items-center justify-center rounded-full text-[10px] font-bold uppercase tracking-wider ${colors.avatar}">${mName.charAt(0)}</span>
          <span class="font-semibold text-body truncate max-w-[80px]">${mName}</span>
          <span class="font-mono text-ink ml-auto font-bold tabular-nums">${state.currency}${personShare.toFixed(2)}</span>
        `;
        breakdownList.appendChild(itemCard);
      }
      detailsPanel.appendChild(breakdownList);
      
      // Delete button row
      if (!isReadOnly) {
        const panelFooter = document.createElement('div');
        panelFooter.className = 'flex justify-end pt-2 border-t border-hairline';
        
        const deleteBtn = document.createElement('button');
        deleteBtn.type = 'button';
        deleteBtn.className = 'inline-flex h-9 items-center justify-center rounded-lg border border-error/20 hover:border-error bg-canvas text-error px-4 text-xs font-semibold hover:bg-error-soft/30 transition-all cursor-pointer active:scale-95 shadow-sm gap-1.5';
        deleteBtn.innerHTML = `
          <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path>
          </svg>
          Delete Expense
        `;
        deleteBtn.addEventListener('click', (e) => {
          e.stopPropagation();
          container.classList.add('scale-95', 'opacity-0');
          setTimeout(() => {
            removeExpense(exp.id);
          }, 200);
        });
        panelFooter.appendChild(deleteBtn);
        detailsPanel.appendChild(panelFooter);
      }
      
      container.appendChild(mainContent);
      container.appendChild(detailsPanel);
      
      // Click toggle handler
      mainContent.addEventListener('click', () => {
        const isCollapsed = detailsPanel.classList.contains('hidden');
        if (isCollapsed) {
          detailsPanel.classList.remove('hidden');
          chevron.classList.add('rotate-180');
        } else {
          detailsPanel.classList.add('hidden');
          chevron.classList.remove('rotate-180');
        }
      });
      
      elements.expensesListContainer.appendChild(container);
      
      elements.expensesListContainer.appendChild(container);
    }
  }

  function renderCalculations() {
    const summary = calculateSplit(state);
    
    // Total spend with count-up animation
    if (totalSpendAnimFrameId !== null) {
      cancelAnimationFrame(totalSpendAnimFrameId);
      totalSpendAnimFrameId = null;
    }

    if (lastTotalSpend !== summary.totalSpend) {
      animateValue(elements.summaryTotalSpend, lastTotalSpend, summary.totalSpend, 300);
      lastTotalSpend = summary.totalSpend;
    } else {
      elements.summaryTotalSpend.innerHTML = state.currency + summary.totalSpend.toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 2 });
    }
    
    // Find top payer
    let maxPaid = 0;
    let topPayerId = '';
    
    Object.values(summary.memberSummaries).forEach((s) => {
      if (s.paid > maxPaid) {
        maxPaid = s.paid;
        topPayerId = s.memberId;
      }
    });
    
    if (topPayerId && maxPaid > 0) {
      const topPayerName = state.members.find(m => m.id === topPayerId)?.name || '';
      elements.summaryTopPayer.textContent = topPayerName;
      elements.topPayerBadgeContainer.classList.remove('hidden');
      elements.topPayerBadgeContainer.classList.add('flex');
    } else {
      elements.topPayerBadgeContainer.classList.add('hidden');
      elements.topPayerBadgeContainer.classList.remove('flex');
    }

    // Render Table
    elements.summaryTableBody.innerHTML = '';
    
    if (state.members.length === 0) {
      elements.summaryTableBody.innerHTML = `
        <tr>
          <td colspan="4" class="p-4 text-xs text-mute italic text-center">No group members. Add members to see calculations.</td>
        </tr>
      `;
    } else {
      for (const m of state.members) {
        const ms = summary.memberSummaries[m.id] || { paid: 0, owed: 0, net: 0 };
        const tr = document.createElement('tr');
        tr.className = 'border-b border-hairline hover:bg-canvas-soft-2 transition-colors';
        
        const nameTd = document.createElement('td');
        nameTd.className = 'p-3 text-sm text-ink font-semibold';
        nameTd.textContent = m.name;
        
        const paidTd = document.createElement('td');
        paidTd.className = 'p-3 text-sm text-body text-right font-mono tabular-nums';
        paidTd.textContent = `${state.currency}${ms.paid.toFixed(2)}`;
        
        const owedTd = document.createElement('td');
        owedTd.className = 'p-3 text-sm text-body text-right font-mono tabular-nums';
        owedTd.textContent = `${state.currency}${ms.owed.toFixed(2)}`;
        
        const netTd = document.createElement('td');
        netTd.className = 'p-3 text-sm text-right font-mono font-semibold tabular-nums';
        
        if (ms.net > 0.01) {
          netTd.className += ' text-emerald-500'; // Receiver
          netTd.textContent = `+${state.currency}${ms.net.toFixed(2)}`;
        } else if (ms.net < -0.01) {
          netTd.className += ' text-rose-500'; // Payer
          netTd.textContent = `-${state.currency}${Math.abs(ms.net).toFixed(2)}`;
        } else {
          netTd.className += ' text-mute';
          netTd.textContent = `${state.currency}0.00`;
        }
        
        tr.appendChild(nameTd);
        tr.appendChild(paidTd);
        tr.appendChild(owedTd);
        tr.appendChild(netTd);
        elements.summaryTableBody.appendChild(tr);
      }
    }

    // Render Settlements
    elements.settlementsListContainer.innerHTML = '';
    
    if (summary.settlements.length === 0) {
      elements.settlementsListContainer.appendChild(elements.emptySettlementsPlaceholder);
    } else {
      for (const item of summary.settlements) {
        const fromName = state.members.find(m => m.id === item.from)?.name || 'Deleted Member';
        const toName = state.members.find(m => m.id === item.to)?.name || 'Deleted Member';
        
        const card = document.createElement('div');
        card.className = 'rounded-xl border border-hairline bg-canvas p-4 shadow-sm flex flex-col sm:flex-row sm:items-center justify-between gap-4 transition-all hover:shadow-md animate-fade-in';
        
        // Left Side: Flow Info
        const flowDiv = document.createElement('div');
        flowDiv.className = 'flex items-center gap-3 flex-wrap';

        const fromColors = getAvatarColor(fromName);
        const toColors = getAvatarColor(toName);

        // Payer avatar + name
        const payerWrapper = document.createElement('div');
        payerWrapper.className = 'flex items-center gap-2';
        payerWrapper.innerHTML = `
          <span class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full text-xs font-bold uppercase tracking-wider ${fromColors.avatar}">${fromName.charAt(0)}</span>
          <span class="font-semibold text-rose-500 dark:text-rose-400 text-sm">${fromName}</span>
        `;

        // Flow arrow
        const arrowSpan = document.createElement('span');
        arrowSpan.className = 'text-xs text-mute flex items-center gap-1 font-bold animate-pulse px-1';
        arrowSpan.innerHTML = 'pays <svg class="h-4.5 w-4.5 text-indigo-500" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>';

        // Receiver avatar + name
        const receiverWrapper = document.createElement('div');
        receiverWrapper.className = 'flex items-center gap-2';
        receiverWrapper.innerHTML = `
          <span class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full text-xs font-bold uppercase tracking-wider ${toColors.avatar}">${toName.charAt(0)}</span>
          <span class="font-semibold text-emerald-500 dark:text-emerald-400 text-sm">${toName}</span>
        `;

        flowDiv.appendChild(payerWrapper);
        flowDiv.appendChild(arrowSpan);
        flowDiv.appendChild(receiverWrapper);

        // Right Side: Amount and Action
        const rightDiv = document.createElement('div');
        rightDiv.className = 'flex items-center justify-between sm:justify-start gap-4 w-full sm:w-auto ml-auto sm:ml-0';

        const amountSpan = document.createElement('span');
        amountSpan.className = 'text-base font-bold text-indigo-500 dark:text-indigo-400 font-mono tabular-nums';
        amountSpan.textContent = `${state.currency}${item.amount.toFixed(2)}`;

        const settleBtn = document.createElement('button');
        settleBtn.type = 'button';
        settleBtn.className = 'text-xs font-semibold border border-indigo-500/20 hover:border-indigo-500/30 rounded-full px-3 py-1.5 bg-indigo-500/5 hover:bg-indigo-500/10 text-indigo-500 transition-all active:scale-95 cursor-pointer';
        settleBtn.textContent = 'Mark Settle';
        settleBtn.addEventListener('click', () => {
          settleDebt(item.from, item.to, item.amount);
        });

        rightDiv.appendChild(amountSpan);
        if (!isReadOnly) {
          rightDiv.appendChild(settleBtn);
        }

        card.appendChild(flowDiv);
        card.appendChild(rightDiv);
        elements.settlementsListContainer.appendChild(card);
      }
    }
  }

  function renderShareActions() {
    const url = encodeStateToUrl(state);
    elements.shareLinkInput.value = url;
    elements.whatsappShareBtn.href = getWhatsAppShareUrl(url, state.name);

    if (isUrlLengthWarning(url)) {
      elements.urlLimitWarning.classList.remove('hidden');
    } else {
      elements.urlLimitWarning.classList.add('hidden');
    }

    try {
      QRCode.toCanvas(elements.shareQrCanvas, url, {
        width: 140,
        margin: 1,
        color: {
          dark: '#18181b',
          light: '#ffffff'
        }
      }, (err) => {
        if (err) console.error('Failed generating QR code:', err);
      });
    } catch (e) {
      console.error('QR code render crash guard:', e);
    }
  }

  // Settle Debt Action
  function settleDebt(fromId: string, toId: string, amount: number) {
    if (isReadOnly) return;
    const fromName = state.members.find(m => m.id === fromId)?.name || 'Member';
    const toName = state.members.find(m => m.id === toId)?.name || 'Member';
    
    const newExpense: Expense = {
      id: 'e_' + Math.random().toString(36).substring(2, 9),
      title: `Settle: ${fromName} → ${toName}`,
      category: 'other',
      amount: amount,
      paidBy: fromId,
      splitAmong: [toId],
      isSettlement: true
    };

    state.expenses.push(newExpense);
    saveCurrentGroup(state);
    populateRecentsDropdown();
    renderAll();
    showToast(`Logged settlement: ${fromName} paid ${toName} ${state.currency}${amount.toFixed(2)}.`);
  }

  // Mutator Actions
  function addMember(name: string) {
    if (isReadOnly) return;
    const err = validateMemberName(name, state.members);
    if (err) {
      elements.memberValidationError.textContent = err;
      elements.memberValidationError.classList.remove('hidden');
      return;
    }

    elements.memberValidationError.classList.add('hidden');
    elements.newMemberName.value = '';

    const newM: Member = {
      id: 'm_' + Math.random().toString(36).substring(2, 9),
      name: name.trim()
    };

    state.members.push(newM);
    saveCurrentGroup(state);
    populateRecentsDropdown();
    renderAll();
    showToast(`Added member "${newM.name}".`);
  }

  function removeMember(id: string) {
    if (isReadOnly) return;
    const member = state.members.find(m => m.id === id);
    if (!member) return;

    state.members = state.members.filter(m => m.id !== id);

    state.expenses = state.expenses.map(e => {
      const cleanSplit = e.splitAmong.filter(mId => mId !== id);
      return {
        ...e,
        splitAmong: cleanSplit
      };
    }).filter(e => e.paidBy !== id && e.splitAmong.length > 0);

    saveCurrentGroup(state);
    populateRecentsDropdown();
    renderAll();
    showToast(`Removed member "${member.name}".`);
  }

  function removeExpense(id: string) {
    if (isReadOnly) return;
    const expIndex = state.expenses.findIndex(e => e.id === id);
    if (expIndex === -1) return;
    
    const exp = state.expenses[expIndex];
    lastDeletedExpense = exp;
    
    state.expenses = state.expenses.filter(e => e.id !== id);
    saveCurrentGroup(state);
    populateRecentsDropdown();
    renderAll();
    showUndoToast(`Deleted expense "${exp.title}".`);
  }

  // Event Bindings
  elements.groupName.addEventListener('input', () => {
    if (isReadOnly) return;
    state.name = elements.groupName.value.trim() || 'Untitled Split';
    saveCurrentGroup(state);
    populateRecentsDropdown();
    renderShareActions();
  });

  elements.currencySelector.addEventListener('change', () => {
    if (isReadOnly) return;
    state.currency = elements.currencySelector.value;
    elements.expenseAmountSymbol.textContent = state.currency;
    
    // Instantly update total spend currency display in calculations card
    if (totalSpendAnimFrameId !== null) {
      cancelAnimationFrame(totalSpendAnimFrameId);
      totalSpendAnimFrameId = null;
    }
    const summary = calculateSplit(state);
    elements.summaryTotalSpend.innerHTML = state.currency + summary.totalSpend.toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 2 });
    
    saveCurrentGroup(state);
    renderAll();
  });

  elements.modeTravelBtn.addEventListener('click', () => {
    if (isReadOnly) return;
    if (state.mode === 'travel') return;
    updateModeUI('travel');
    populateCategories();
    saveCurrentGroup(state);
    renderAll();
  });

  elements.modeSubscriptionBtn.addEventListener('click', () => {
    if (isReadOnly) return;
    if (state.mode === 'subscription') return;
    updateModeUI('subscription');
    populateCategories();
    saveCurrentGroup(state);
    renderAll();
  });

  elements.recentSplitsSelector.addEventListener('change', () => {
    if (isReadOnly) {
      isReadOnly = false;
      // Restore UI controls from read-only mode
      if (elements.groupName) elements.groupName.disabled = false;
      if (elements.currencySelector) elements.currencySelector.disabled = false;
      if (elements.modeTravelBtn) elements.modeTravelBtn.classList.remove('pointer-events-none', 'opacity-50');
      if (elements.modeSubscriptionBtn) elements.modeSubscriptionBtn.classList.remove('pointer-events-none', 'opacity-50');
      
      if (elements.resetGroupBtn) elements.resetGroupBtn.classList.remove('hidden');
      if (elements.clearAllMemoryBtn) elements.clearAllMemoryBtn.classList.remove('hidden');
      if (elements.addMemberForm) elements.addMemberForm.classList.remove('hidden');
      if (elements.addExpenseCardContainer) elements.addExpenseCardContainer.classList.remove('hidden');
      if (elements.mobileAddExpenseFab) elements.mobileAddExpenseFab.classList.remove('hidden');
    }

    const selectedId = elements.recentSplitsSelector.value;
    if (!selectedId) return;

    const recents = loadRecents();
    const found = recents.find(r => r.id === selectedId);
    if (found) {
      state = found;
      elements.groupName.value = state.name;
      elements.currencySelector.value = state.currency;
      elements.expenseAmountSymbol.textContent = state.currency;
      updateModeUI(state.mode);
      populateCategories();
      
      saveCurrentGroup(state);
      renderAll();
      showToast(`Loaded split "${state.name}".`);
    }
  });

  elements.expenseCategory.addEventListener('change', toggleStreamingServiceVisibility);

  elements.resetGroupBtn.addEventListener('click', () => {
    if (isReadOnly) return;
    if (!confirm('Are you sure you want to completely reset this group split? All current expenses and members will be cleared.')) {
      return;
    }

    state = {
      id: Math.random().toString(36).substring(2, 9),
      name: 'My Trip',
      currency: '$',
      members: [],
      expenses: [],
      mode: 'travel',
    };
    
    // Reset state track variables
    lastTotalSpend = 0;
    lastDeletedExpense = null;
    
    elements.groupName.value = state.name;
    elements.currencySelector.value = state.currency;
    elements.expenseAmountSymbol.textContent = state.currency;
    updateModeUI(state.mode);
    populateCategories();
    
    // Reset split type toggle
    currentSplitType = 'equal';
    elements.splitTypeEqualBtn.className = 'text-[10px] font-bold py-1 px-2.5 rounded-lg transition-all bg-white dark:bg-zinc-700 text-zinc-950 dark:text-zinc-100 shadow-sm cursor-pointer';
    elements.splitTypeUnequalBtn.className = 'text-[10px] font-bold py-1 px-2.5 rounded-lg transition-all text-zinc-500 hover:text-zinc-950 dark:text-zinc-400 cursor-pointer';
    elements.unequalStatusText.classList.add('hidden');
    
    saveCurrentGroup(state);
    sessionStorage.setItem('toast_message', 'Group reset successfully.');
    window.location.reload();
  });

  elements.clearAllMemoryBtn.addEventListener('click', () => {
    if (isReadOnly) return;
    if (!confirm('WARNING: This will completely delete all current groups, all recent history, and all stored data from this device. This action CANNOT be undone. Are you sure you want to proceed?')) {
      return;
    }

    clearAll();
    
    // Reset state to initial clean state and save
    state = {
      id: Math.random().toString(36).substring(2, 9),
      name: 'My Trip',
      currency: '$',
      members: [],
      expenses: [],
      mode: 'travel',
    };
    saveCurrentGroup(state);
    
    sessionStorage.setItem('toast_message', 'All stored splits and history cleared.');
    window.location.reload();
  });

  // Add Member Form
  elements.addMemberForm.addEventListener('submit', (e) => {
    e.preventDefault();
    if (isReadOnly) return;
    const val = elements.newMemberName.value;
    addMember(val);
  });

  // Checkbox Selectors
  elements.splitSelectAll.addEventListener('click', () => {
    if (isReadOnly) return;
    const rows = elements.splitMembersCheckboxes.querySelectorAll('.split-member-row');
    rows.forEach((row: any) => {
      const cb = row.querySelector('input[type="checkbox"]');
      const numInput = row.querySelector('input[type="number"]');
      if (cb) {
        cb.checked = true;
        if (numInput) {
          numInput.disabled = false;
          numInput.classList.remove('opacity-40');
        }
      }
    });
    updateUnequalSplitStatus();
  });

  elements.splitDeselectAll.addEventListener('click', () => {
    if (isReadOnly) return;
    const rows = elements.splitMembersCheckboxes.querySelectorAll('.split-member-row');
    rows.forEach((row: any) => {
      const cb = row.querySelector('input[type="checkbox"]');
      const numInput = row.querySelector('input[type="number"]');
      if (cb) {
        cb.checked = false;
        if (numInput) {
          numInput.disabled = true;
          numInput.classList.add('opacity-40');
          numInput.value = '';
        }
      }
    });
    updateUnequalSplitStatus();
  });

  // Split type toggles
  elements.splitTypeEqualBtn.addEventListener('click', () => {
    if (isReadOnly) return;
    if (currentSplitType === 'equal') return;
    currentSplitType = 'equal';
    
    // Toggle active state classes
    elements.splitTypeEqualBtn.className = 'text-[10px] font-bold py-1 px-2.5 rounded-lg transition-all bg-white dark:bg-zinc-700 text-zinc-950 dark:text-zinc-100 shadow-sm cursor-pointer';
    elements.splitTypeUnequalBtn.className = 'text-[10px] font-bold py-1 px-2.5 rounded-lg transition-all text-zinc-500 hover:text-zinc-950 dark:text-zinc-400 cursor-pointer';
    
    // Hide inputs
    const rows = elements.splitMembersCheckboxes.querySelectorAll('.split-member-row');
    rows.forEach((row: any) => {
      const container = row.querySelector('div.relative');
      if (container) container.classList.add('hidden');
    });
    
    updateUnequalSplitStatus();
  });

  elements.splitTypeUnequalBtn.addEventListener('click', () => {
    if (isReadOnly) return;
    if (currentSplitType === 'unequal') return;
    currentSplitType = 'unequal';
    
    // Toggle active state classes
    elements.splitTypeEqualBtn.className = 'text-[10px] font-bold py-1 px-2.5 rounded-lg transition-all text-zinc-500 hover:text-zinc-950 dark:text-zinc-400 cursor-pointer';
    elements.splitTypeUnequalBtn.className = 'text-[10px] font-bold py-1 px-2.5 rounded-lg transition-all bg-white dark:bg-zinc-700 text-zinc-950 dark:text-zinc-100 shadow-sm cursor-pointer';
    
    // Show inputs
    const rows = elements.splitMembersCheckboxes.querySelectorAll('.split-member-row');
    rows.forEach((row: any) => {
      const container = row.querySelector('div.relative');
      if (container) {
        container.classList.remove('hidden');
        // Enable input if checkbox is checked
        const cb = row.querySelector('input[type="checkbox"]');
        const numInput = container.querySelector('input[type="number"]');
        if (cb && numInput) {
          numInput.disabled = !cb.checked;
          if (!cb.checked) {
            numInput.classList.add('opacity-40');
          } else {
            numInput.classList.remove('opacity-40');
          }
        }
      }
    });
    
    updateUnequalSplitStatus();
  });

  elements.expenseAmount.addEventListener('input', () => {
    updateUnequalSplitStatus();
  });

  // Add Expense
  elements.addExpenseForm.addEventListener('submit', (e) => {
    e.preventDefault();
    if (isReadOnly) return;
    
    const title = elements.expenseTitle.value;
    const category = elements.expenseCategory.value;
    const subCategory = category === 'streaming' ? elements.streamingService.value : undefined;
    const amount = parseFloat(elements.expenseAmount.value);
    const paidBy = elements.expensePaidBy.value;
    
    const splitAmong: string[] = [];
    const shares: Record<string, number> = {};
    
    const rows = elements.splitMembersCheckboxes.querySelectorAll('.split-member-row');
    let shareSum = 0;
    
    rows.forEach((row: any) => {
      const cb = row.querySelector('input[type="checkbox"]');
      if (cb && cb.checked) {
        splitAmong.push(cb.value);
        if (currentSplitType === 'unequal') {
          const numInput = row.querySelector('input[type="number"]');
          const val = parseFloat(numInput?.value || '0') || 0;
          shares[cb.value] = val;
          shareSum += val;
        }
      }
    });

    const errors = validateExpenseData(title, amount, paidBy, splitAmong, state.expenses.length);

    elements.errExpenseTitle.classList.add('hidden');
    elements.errExpenseAmount.classList.add('hidden');
    elements.errExpensePaidBy.classList.add('hidden');
    elements.errExpenseSplitAmong.classList.add('hidden');
    elements.expenseFormErrorSummary.classList.add('hidden');

    if (errors) {
      elements.expenseFormErrorSummary.classList.remove('hidden');
      if (errors.title) {
        elements.errExpenseTitle.textContent = errors.title;
        elements.errExpenseTitle.classList.remove('hidden');
      }
      if (errors.amount) {
        elements.errExpenseAmount.textContent = errors.amount;
        elements.errExpenseAmount.classList.remove('hidden');
      }
      if (errors.paidBy) {
        elements.errExpensePaidBy.textContent = errors.paidBy;
        elements.errExpensePaidBy.classList.remove('hidden');
      }
      if (errors.splitAmong) {
        elements.errExpenseSplitAmong.textContent = errors.splitAmong;
        elements.errExpenseSplitAmong.classList.remove('hidden');
      }
      if (errors.general) {
        elements.expenseFormErrorSummary.textContent = errors.general;
      }
      return;
    }

    if (currentSplitType === 'unequal') {
      const difference = Math.abs(amount - shareSum);
      if (difference >= 0.01) {
        elements.errExpenseSplitAmong.textContent = `The sum of shares (${state.currency}${shareSum.toFixed(2)}) must equal the total amount (${state.currency}${amount.toFixed(2)}).`;
        elements.errExpenseSplitAmong.classList.remove('hidden');
        elements.expenseFormErrorSummary.classList.remove('hidden');
        return;
      }
    }

    const newExpense: Expense = {
      id: 'e_' + Math.random().toString(36).substring(2, 9),
      title: title.trim(),
      category,
      subCategory,
      amount,
      paidBy,
      splitAmong,
      shares: currentSplitType === 'unequal' ? shares : undefined
    };

    state.expenses.push(newExpense);
    saveCurrentGroup(state);
    populateRecentsDropdown();
    
    // Reset Form inputs
    elements.expenseTitle.value = '';
    elements.expenseAmount.value = '';
    
    // Reset split type toggle
    currentSplitType = 'equal';
    elements.splitTypeEqualBtn.className = 'text-[10px] font-bold py-1 px-2.5 rounded-md transition-all bg-canvas text-ink shadow-sm cursor-pointer';
    elements.splitTypeUnequalBtn.className = 'text-[10px] font-bold py-1 px-2.5 rounded-md transition-all text-body hover:text-ink cursor-pointer';
    elements.unequalStatusText.classList.add('hidden');
    
    // Close sheet on mobile
    if (window.innerWidth < 768) {
      closeMobileSheet();
    }

    renderAll();
    showToast(`Logged expense "${newExpense.title}".`);
  });

  // Copy URL
  elements.copyLinkBtn.addEventListener('click', () => {
    const url = elements.shareLinkInput.value;
    navigator.clipboard.writeText(url).then(() => {
      elements.copyLinkBtn.textContent = 'Copied!';
      showToast('Link copied to clipboard.');
      setTimeout(() => {
        elements.copyLinkBtn.textContent = 'Copy';
      }, 2000);
    }).catch(err => {
      console.error('Failed to copy link:', err);
      showToast('Failed to copy link.', 'error');
    });
  });

  // PDF Export Generation
  elements.exportPdfBtn.addEventListener('click', () => {
    try {
      if (state.members.length === 0) {
        showToast('Add members before exporting PDF.', 'error');
        return;
      }

      const summary = calculateSplit(state);
      const doc = new jsPDF();
      
      const primaryColor = [23, 23, 23];
      const grayColor = [136, 136, 136];
      const lightLineColor = 230;

      doc.setFont('Helvetica', 'bold');
      doc.setFontSize(22);
      doc.setTextColor(primaryColor[0], primaryColor[1], primaryColor[2]);
      doc.text('SplitWhat Expense Summary', 20, 20);

      doc.setFont('Helvetica', 'normal');
      doc.setFontSize(10);
      doc.setTextColor(grayColor[0], grayColor[1], grayColor[2]);
      doc.text(`Group: ${state.name}`, 20, 30);
      doc.text(`Date: ${new Date().toLocaleDateString()} • Mode: ${state.mode === 'travel' ? 'Travel' : 'Subscription'}`, 20, 35);
      doc.text(`Total Spend: ${state.currency}${summary.totalSpend.toFixed(2)}`, 20, 40);

      doc.setDrawColor(lightLineColor);
      doc.line(20, 45, 190, 45);

      doc.setFont('Helvetica', 'bold');
      doc.setFontSize(14);
      doc.setTextColor(primaryColor[0], primaryColor[1], primaryColor[2]);
      doc.text('Balance Sheet', 20, 55);

      doc.setFontSize(10);
      doc.setTextColor(grayColor[0], grayColor[1], grayColor[2]);
      doc.text('Member', 20, 65);
      doc.text('Paid', 70, 65, { align: 'right' });
      doc.text('Owed', 110, 65, { align: 'right' });
      doc.text('Net Balance', 150, 65, { align: 'right' });
      doc.line(20, 67, 190, 67);

      let yOffset = 75;
      doc.setFont('Helvetica', 'normal');
      doc.setTextColor(primaryColor[0], primaryColor[1], primaryColor[2]);

      for (const m of state.members) {
        const ms = summary.memberSummaries[m.id] || { paid: 0, owed: 0, net: 0 };
        doc.text(m.name, 20, yOffset);
        doc.text(`${state.currency}${ms.paid.toFixed(2)}`, 70, yOffset, { align: 'right' });
        doc.text(`${state.currency}${ms.owed.toFixed(2)}`, 110, yOffset, { align: 'right' });
        
        let netString = '';
        if (ms.net > 0.01) {
          netString = `+${state.currency}${ms.net.toFixed(2)}`;
        } else if (ms.net < -0.01) {
          netString = `-${state.currency}${Math.abs(ms.net).toFixed(2)}`;
        } else {
          netString = `${state.currency}0.00`;
        }
        
        doc.text(netString, 150, yOffset, { align: 'right' });
        yOffset += 8;
      }

      doc.line(20, yOffset, 190, yOffset);
      yOffset += 12;

      doc.setFont('Helvetica', 'bold');
      doc.setFontSize(14);
      doc.text('Settlement Directions', 20, yOffset);
      yOffset += 10;

      doc.setFont('Helvetica', 'normal');
      doc.setFontSize(10);
      
      if (summary.settlements.length === 0) {
        doc.text('Everyone is fully settled! No transactions required.', 20, yOffset);
      } else {
        for (const item of summary.settlements) {
          const fromName = state.members.find(m => m.id === item.from)?.name || 'Deleted Member';
          const toName = state.members.find(m => m.id === item.to)?.name || 'Deleted Member';
          doc.text(`-  [ ]  ${fromName} pays ${toName}   -->   ${state.currency}${item.amount.toFixed(2)}`, 20, yOffset);
          yOffset += 8;
        }
      }

      yOffset += 12;
      doc.line(20, yOffset, 190, yOffset);
      yOffset += 8;
      
      doc.setFontSize(8);
      doc.setTextColor(grayColor[0], grayColor[1], grayColor[2]);
      doc.text('Generated instantly by SplitWhat — Private client-side bill splitting.', 20, yOffset);

      const filename = `${state.name.toLowerCase().replace(/[^a-z0-9]+/g, '_')}_summary.pdf`;
      doc.save(filename);
      showToast('PDF summary downloaded.');
    } catch (e) {
      console.error('PDF export crash guard:', e);
      showToast('Failed to export PDF.', 'error');
    }
  });

  // Run initial loading
  init();
</script>
