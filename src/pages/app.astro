  // Avatar Hash Color Generator
  function getAvatarColor(name: string) {
    let hash = 0;
    for (let i = 0; i < name.length; i++) {
      hash = name.charCodeAt(i) + ((hash << 5) - hash);
    }
    const colors = [
      { bg: 'bg-indigo-500/10 text-indigo-500 border-indigo-500/20', avatar: 'bg-indigo-500 text-white' },
      { bg: 'bg-violet-500/10 text-violet-500 border-violet-500/20', avatar: 'bg-violet-500 text-white' },
      { bg: 'bg-pink-500/10 text-pink-500 border-pink-500/20', avatar: 'bg-pink-500 text-white' },
      { bg: 'bg-emerald-500/10 text-emerald-500 border-emerald-500/20', avatar: 'bg-emerald-500 text-white' },
      { bg: 'bg-amber-500/10 text-amber-500 border-amber-500/20', avatar: 'bg-amber-500 text-white' },
      { bg: 'bg-sky-500/10 text-sky-500 border-sky-500/20', avatar: 'bg-sky-500 text-white' },
      { bg: 'bg-rose-500/10 text-rose-500 border-rose-500/20', avatar: 'bg-rose-500 text-white' },
      { bg: 'bg-teal-500/10 text-teal-500 border-teal-500/20', avatar: 'bg-teal-500 text-white' },
    ];
    const index = Math.abs(hash) % colors.length;
    return colors[index];
  }

