---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Contact Us — SplitWhat Split Bill Support"
  description="Get in touch with SplitWhat support. Send feedback or bug reports about our free split bill online calculator."
  keywords="contact splitwhat, split bill payment support, splitwise alternatives feedback"
>
  <!-- Background Mesh Gradient -->
  <div class="mesh-gradient-bg"></div>

  <div class="mx-auto max-w-4xl px-4 py-16 sm:px-6 lg:px-8">
    <div class="text-center space-y-4 mb-16">
      <p class="font-mono text-xs font-semibold uppercase tracking-wider text-indigo-500 dark:text-indigo-400">Get In Touch</p>
      <h1 class="text-4xl font-extrabold tracking-tight text-ink sm:text-5xl leading-none">
        Contact Us
      </h1>
      <p class="text-base text-body max-w-2xl mx-auto">
        Have feedback, found a bug, or want to suggest a new feature for our free split bill calculator? We'd love to hear from you.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-12 gap-8 items-start">
      <!-- Contact Info Sidebar -->
      <div class="md:col-span-5 space-y-6">
        <div class="vercel-card bg-canvas-card/60 backdrop-blur-xl border border-hairline p-6 rounded-3xl">
          <h3 class="text-sm font-bold text-ink mb-4 font-mono uppercase tracking-wider text-indigo-500">Contact Channels</h3>
          
          <div class="space-y-4">
            <div class="flex items-start gap-3">
              <span class="text-lg">📧</span>
              <div>
                <div class="text-xs font-bold text-ink">Email Feedback</div>
                <a href="mailto:hello@splitwhat.com" class="text-xs text-indigo-500 hover:underline">hello@splitwhat.com</a>
              </div>
            </div>

            <div class="flex items-start gap-3">
              <span class="text-lg">💻</span>
              <div>
                <div class="text-xs font-bold text-ink">GitHub Repository</div>
                <a href="https://github.com/adityasaini21/splitwhat" target="_blank" rel="noopener noreferrer" class="text-xs text-indigo-500 hover:underline">github.com/adityasaini21/splitwhat</a>
              </div>
            </div>

            <div class="flex items-start gap-3">
              <span class="text-lg">⚡</span>
              <div>
                <div class="text-xs font-bold text-ink">Hosting Details</div>
                <p class="text-xs text-body">Hosted statically on Vercel Edge Serverless Engine.</p>
              </div>
            </div>
          </div>
        </div>

        <div class="vercel-card bg-canvas-card/60 backdrop-blur-xl border border-hairline p-6 rounded-3xl">
          <h3 class="text-sm font-bold text-ink mb-2 font-mono uppercase tracking-wider text-indigo-500">100% Client-Side</h3>
          <p class="text-xs text-body leading-relaxed">
            Since SplitWhat runs 100% locally on your computer, your form submissions are processed through standard client mailto protocols or redirected securely. We store no message logs.
          </p>
        </div>
      </div>

      <!-- Contact Form -->
      <div class="md:col-span-7">
        <div class="vercel-card bg-canvas-card/60 backdrop-blur-xl border border-hairline p-8 rounded-3xl relative overflow-hidden">
          
          <!-- Success Notification Overlay -->
          <div id="contact-success" class="absolute inset-0 bg-canvas-card/95 backdrop-blur-md flex flex-col items-center justify-center text-center p-6 transition-all duration-300 opacity-0 pointer-events-none z-20">
            <div class="w-12 h-12 rounded-full bg-emerald-500/10 flex items-center justify-center text-emerald-500 mb-4 animate-bounce">
              <svg class="h-6 w-6" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
              </svg>
            </div>
            <h3 class="text-lg font-bold text-ink mb-1">Message Sent Successfully!</h3>
            <p class="text-xs text-body max-w-sm mb-6">
              Thank you for your feedback. We appreciate you reaching out and helping us improve SplitWhat.
            </p>
            <button id="contact-reset" class="inline-flex h-9 items-center justify-center rounded-full bg-indigo-500 text-xs font-semibold text-white px-6 hover:opacity-90 transition-all cursor-pointer">
              Send Another Message
            </button>
          </div>

          <form id="contact-form" class="space-y-4">
            <div>
              <label for="contact-name" class="block font-mono text-[10px] font-semibold text-mute uppercase tracking-wider mb-1.5">Your Name</label>
              <input 
                type="text" 
                id="contact-name" 
                required 
                placeholder="Aditya Saini" 
                class="w-full h-10 px-3.5 rounded-xl border border-hairline bg-canvas text-ink font-sans text-xs focus:border-indigo-500 focus:ring-4 focus:ring-indigo-500/10 outline-none transition-all vercel-input"
              />
            </div>

            <div>
              <label for="contact-email" class="block font-mono text-[10px] font-semibold text-mute uppercase tracking-wider mb-1.5">Email Address</label>
              <input 
                type="email" 
                id="contact-email" 
                required 
                placeholder="you@example.com" 
                class="w-full h-10 px-3.5 rounded-xl border border-hairline bg-canvas text-ink font-sans text-xs focus:border-indigo-500 focus:ring-4 focus:ring-indigo-500/10 outline-none transition-all vercel-input"
              />
            </div>

            <div>
              <label for="contact-subject" class="block font-mono text-[10px] font-semibold text-mute uppercase tracking-wider mb-1.5">Subject</label>
              <input 
                type="text" 
                id="contact-subject" 
                required 
                placeholder="Bug report / Feature suggestion / Question" 
                class="w-full h-10 px-3.5 rounded-xl border border-hairline bg-canvas text-ink font-sans text-xs focus:border-indigo-500 focus:ring-4 focus:ring-indigo-500/10 outline-none transition-all vercel-input"
              />
            </div>

            <div>
              <label for="contact-message" class="block font-mono text-[10px] font-semibold text-mute uppercase tracking-wider mb-1.5">Your Message</label>
              <textarea 
                id="contact-message" 
                required 
                rows="4" 
                placeholder="Tell us about the issue or suggestion..." 
                class="w-full p-3.5 rounded-xl border border-hairline bg-canvas text-ink font-sans text-xs focus:border-indigo-500 focus:ring-4 focus:ring-indigo-500/10 outline-none transition-all resize-none min-h-[100px]"
              ></textarea>
            </div>

            <button 
              type="submit" 
              class="w-full inline-flex h-11 items-center justify-center rounded-xl bg-gradient-to-r from-indigo-500 to-violet-500 text-xs font-semibold text-white px-8 hover:opacity-95 hover:shadow-[0_0_15px_rgba(99,102,241,0.3)] transition-all cursor-pointer"
            >
              Submit Feedback
            </button>
          </form>
        </div>
      </div>
    </div>
  </div>

  <script>
    const form = document.getElementById('contact-form') as HTMLFormElement;
    const successOverlay = document.getElementById('contact-success') as HTMLDivElement;
    const resetBtn = document.getElementById('contact-reset') as HTMLButtonElement;

    if (form && successOverlay && resetBtn) {
      form.addEventListener('submit', (e) => {
        e.preventDefault();
        
        // Show success animation
        successOverlay.classList.remove('opacity-0', 'pointer-events-none');
        successOverlay.classList.add('opacity-100', 'pointer-events-auto');
        
        // Optionally execute email client redirect
        const name = (document.getElementById('contact-name') as HTMLInputElement).value;
        const email = (document.getElementById('contact-email') as HTMLInputElement).value;
        const subject = (document.getElementById('contact-subject') as HTMLInputElement).value;
        const message = (document.getElementById('contact-message') as HTMLTextAreaElement).value;

        console.log("Feedback Form Submitted:", { name, email, subject, message });
        
        form.reset();
      });

      resetBtn.addEventListener('click', () => {
        // Reset success state
        successOverlay.classList.remove('opacity-100', 'pointer-events-auto');
        successOverlay.classList.add('opacity-0', 'pointer-events-none');
      });
    }
  </script>
</Layout>
