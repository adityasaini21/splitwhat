---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Split Bill Calculator Free — SplitWhat Online Bill Splitter"
  description="SplitWhat is a free, local-first split bill calculator & online split bill payment manager. The ultimate Splitwise alternative to split bills online for restaurants, trips, and roommates without logging in."
  keywords="split bill, split bill calculator, split bill online calculator, split bill payment, split bill payments, split bill calculator app, split bill calculator free, split bill online, splitwise, what is splitwise, splitwise login, splitwise alternatives, restaurant split bill calculator, free split bill calculator"
>
  <!-- Background Mesh Gradient & Dotted Overlay -->
  <div class="relative overflow-hidden">
    <div class="mesh-gradient-bg opacity-80"></div>
    <div class="absolute inset-0 dotted-bg opacity-20 pointer-events-none z-[-9]"></div>
  </div>

  <!-- Hero Section -->
  <section class="relative overflow-hidden py-20 sm:py-28">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-center">
        <!-- Left Side: Copy and CTAs -->
        <div class="lg:col-span-7 text-center lg:text-left space-y-6">
          <!-- Announcement Banner -->
          <div class="inline-flex items-center gap-2 rounded-full border border-hairline bg-canvas-card/60 backdrop-blur-md px-4 py-1.5 text-xs text-body shadow-sm mb-4 transition-all hover:border-indigo-500/30">
            <span class="relative flex h-2 w-2">
              <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-indigo-400 opacity-75"></span>
              <span class="relative inline-flex rounded-full h-2 w-2 bg-indigo-500"></span>
            </span>
            <span class="font-mono text-[10px] font-bold uppercase tracking-wider text-indigo-500 dark:text-indigo-400">Live Demo</span>
            <span class="h-3 w-px bg-hairline"></span>
            <span>Try the SplitWhat on the right &rarr;</span>
          </div>

          <!-- Tagline -->
          <h1 class="text-4xl font-extrabold tracking-tight text-ink sm:text-6xl max-w-3xl leading-none">
            Split bills.<br />
            Skip the login.<br />
            <span class="bg-gradient-to-r from-indigo-500 via-purple-500 to-pink-500 bg-clip-text text-transparent text-glow">Settle instantly.</span>
          </h1>
          
          <!-- Subcopy -->
          <p class="text-base sm:text-lg text-body max-w-2xl leading-relaxed">
            A privacy-first local-first bill splitter built for journeys, 
            shared flats, and group costs. No accounts. 
            No tracking. Just share a compressed link and you're settled.
          </p>

          <!-- CTA Cluster -->
          <div class="flex flex-col sm:flex-row items-center justify-center lg:justify-start gap-4 pt-4">
            <a 
              href="/app" 
              class="w-full sm:w-auto inline-flex h-12 items-center justify-center rounded-full bg-gradient-to-r from-indigo-500 to-violet-500 px-8 text-base font-semibold text-white hover:opacity-95 hover:shadow-[0_0_20px_rgba(99,102,241,0.4)] transition-all scale-100 hover:scale-105 active:scale-95"
            >
              Start Splitting Free
            </a>
            <a 
              href="#features" 
              class="w-full sm:w-auto inline-flex h-12 items-center justify-center rounded-full border border-hairline bg-canvas-card/60 backdrop-blur-md px-8 text-base font-semibold text-ink hover:bg-canvas-soft hover:border-indigo-500/30 transition-all scale-100 hover:scale-105 active:scale-95 shadow-sm"
            >
              See Bento Features
            </a>
          </div>
        </div>

        <!-- Right Side: Live Simulator (interactive) -->
        <div class="lg:col-span-5 relative">
          <!-- Background glow blob behind card -->
          <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-80 h-80 rounded-full bg-indigo-500/10 dark:bg-indigo-500/5 filter blur-3xl pointer-events-none"></div>
          
          <!-- Glassmorphic Terminal Card -->
          <div class="relative w-full max-w-md mx-auto rounded-3xl border border-hairline bg-canvas-card/75 backdrop-blur-xl shadow-2xl p-6 overflow-hidden border-indigo-500/20 dark:border-indigo-400/10">
            <!-- Simulated App Header -->
            <div class="flex items-center justify-between border-b border-hairline pb-4 mb-4">
              <div class="flex items-center gap-2">
                <span class="relative flex h-2 w-2">
                  <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"></span>
                  <span class="relative inline-flex rounded-full h-2 w-2 bg-emerald-500"></span>
                </span>
                <span class="text-[10px] font-mono font-bold tracking-widest text-ink/75 uppercase">Demo</span>
              </div>
              <div class="flex gap-1.5">
                <span class="w-2.5 h-2.5 rounded-full bg-rose-500/40"></span>
                <span class="w-2.5 h-2.5 rounded-full bg-amber-500/40"></span>
                <span class="w-2.5 h-2.5 rounded-full bg-emerald-500/40"></span>
              </div>
            </div>

            <!-- Content Area -->
            <div class="space-y-4">
              <!-- Simulator Form -->
              <div class="bg-canvas-soft/60 rounded-2xl p-4 border border-hairline">
                <h4 class="text-xs font-bold text-ink mb-3 flex justify-between items-center">
                  <span>Log Expense</span>
                  <span class="text-[9px] font-normal text-mute">Updates instantly</span>
                </h4>
                <div class="grid grid-cols-2 gap-2 mb-2">
                  <div>
                    <label class="block text-[9px] font-mono text-mute mb-1">Description</label>
                    <input type="text" id="sim-desc" placeholder="Pizza, Taxi..." value="Drinks 🍻" class="w-full h-8 text-xs px-2.5 rounded-lg border border-hairline bg-canvas focus:border-indigo-500 focus:outline-none" />
                  </div>
                  <div>
                    <label class="block text-[9px] font-mono text-mute mb-1">Amount ($)</label>
                    <input type="number" id="sim-amount" placeholder="30" value="30" class="w-full h-8 text-xs px-2.5 rounded-lg border border-hairline bg-canvas focus:border-indigo-500 focus:outline-none" />
                  </div>
                </div>
                <div class="grid grid-cols-2 gap-2 items-end">
                  <div>
                    <label class="block text-[9px] font-mono text-mute mb-1">Paid By</label>
                    <select id="sim-paid-by" class="w-full h-8 text-xs px-2.5 rounded-lg border border-hairline bg-canvas focus:border-indigo-500 focus:outline-none">
                      <option value="Alex">Alex</option>
                      <option value="Sam">Sam</option>
                      <option value="Jo">Jo</option>
                    </select>
                  </div>
                  <button id="sim-add-btn" class="w-full h-8 text-xs font-semibold text-white bg-indigo-500 hover:bg-indigo-600 rounded-lg shadow-sm transition-all active:scale-95 cursor-pointer">
                    Add Expense
                  </button>
                </div>
              </div>

              <!-- Simulator Outputs Grid -->
              <div class="grid grid-cols-1 md:grid-cols-2 gap-3 min-h-[280px] md:min-h-0 md:h-[180px]">
                <!-- Column 1: Expense List -->
                <div class="flex flex-col h-full min-h-[130px] md:min-h-0 bg-canvas-soft/30 rounded-2xl p-3 border border-hairline">
                  <h4 class="text-[9px] font-mono font-bold tracking-wider text-mute uppercase mb-2">Expense Logs</h4>
                  <div id="sim-expenses-list" class="flex-1 overflow-y-auto space-y-2 scrollbar-none pr-1">
                    <!-- Dynamic Items -->
                  </div>
                </div>

                <!-- Column 2: Live Balance / Settlement -->
                <div class="flex flex-col h-full min-h-[130px] md:min-h-0 bg-indigo-500/[0.02] dark:bg-indigo-400/[0.01] rounded-2xl p-3 border border-indigo-500/10">
                  <h4 class="text-[9px] font-mono font-bold tracking-wider text-indigo-500 dark:text-indigo-400 uppercase mb-2">Settle Paths</h4>
                  <div id="sim-settlements-list" class="flex-1 overflow-y-auto space-y-2 scrollbar-none pr-1">
                    <!-- Dynamic Settlements -->
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Feature Bento Grid Section -->
  <section id="features" class="scroll-mt-16 border-t border-hairline bg-canvas py-20 sm:py-28 relative">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-3xl mx-auto space-y-3">
        <p class="font-mono text-xs font-semibold uppercase tracking-wider text-indigo-500 dark:text-indigo-400">Local-first expense splitting system</p>
        <h2 class="text-3xl font-extrabold tracking-tight text-ink sm:text-4xl">
          Everything you need. Zero remote databases.
        </h2>
        <p class="text-base text-body">
          We designed SplitWhat with a premium bento-box feature set to show off local-first technology.
        </p>
      </div>

      <!-- Bento Grid Section -->
      <div class="mt-16 grid grid-cols-1 md:grid-cols-6 gap-6">
        
        <!-- Bento 1: No Signup (Col Span 3) -->
        <div class="vercel-card feature-card p-8 md:col-span-3 flex flex-col justify-between" style="--card-hover-border: rgba(99, 102, 241, 0.4); --card-glow: rgba(99, 102, 241, 0.12);">
          <div>
            <div class="h-10 w-10 rounded-xl bg-indigo-500/10 dark:bg-indigo-500/20 text-indigo-500 flex items-center justify-center mb-6 shrink-0">
              <svg class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z"/>
              </svg>
            </div>
            <div class="font-mono text-xs text-mute mb-2 font-semibold">01 / LATENCY ZERO</div>
            <h3 class="text-xl font-bold tracking-tight text-ink">Bypass the Signup Forms</h3>
            <p class="mt-2 text-sm text-body leading-relaxed">
              Why create an account just to split a dinner bill? With SplitWhat, you skip the registration, email verification, and password creation. Click launch, and you are immediately inside your workspace.
            </p>
          </div>
          
          <!-- Visual mockup inside card -->
          <div class="mt-8 bento-graphic h-36 flex items-center justify-center p-4">
            <div class="w-full max-w-[240px] bg-canvas rounded-lg shadow-sm border border-hairline p-3 relative select-none">
              <!-- Overlay skipped banner -->
              <div class="absolute inset-0 bg-indigo-500/10 dark:bg-indigo-500/20 backdrop-blur-[1px] flex items-center justify-center rounded-lg border border-indigo-500/30">
                <span class="px-2.5 py-1 bg-indigo-500 text-white font-mono text-[9px] font-bold rounded-full uppercase tracking-wider shadow">Skip to App &rarr;</span>
              </div>
              <div class="space-y-1.5 opacity-30">
                <div class="h-6 w-full rounded border border-hairline bg-canvas-soft flex items-center justify-between px-2 text-[10px] text-mute">Email Address</div>
                <div class="h-6 w-full rounded border border-hairline bg-canvas-soft flex items-center justify-between px-2 text-[10px] text-mute">Password</div>
                <div class="h-6 w-full rounded bg-indigo-500/50 flex items-center justify-center text-[10px] text-white font-bold">Sign Up</div>
              </div>
            </div>
          </div>
        </div>

        <!-- Bento 2: 100% Client-Side (Col Span 3) -->
        <div class="vercel-card feature-card p-8 md:col-span-3 flex flex-col justify-between" style="--card-hover-border: rgba(16, 185, 129, 0.4); --card-glow: rgba(16, 185, 129, 0.12);">
          <div>
            <div class="h-10 w-10 rounded-xl bg-emerald-500/10 dark:bg-emerald-500/20 text-emerald-500 flex items-center justify-center mb-6 shrink-0">
              <svg class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
              </svg>
            </div>
            <div class="font-mono text-xs text-mute mb-2 font-semibold">02 / PRIVACY FIRST</div>
            <h3 class="text-xl font-bold tracking-tight text-ink">100% Client-Side Architecture</h3>
            <p class="mt-2 text-sm text-body leading-relaxed">
              We don't collect, store, or sell your financial data. All calculations and records reside safely in your browser's LocalStorage. It runs entirely offline, meaning your group budget stays confidential.
            </p>
          </div>

          <!-- Visual mockup inside card -->
          <div class="mt-8 bento-graphic h-36 flex items-center justify-center p-4">
            <div class="flex items-center gap-4 select-none">
              <div class="flex flex-col items-center">
                <div class="h-12 w-12 rounded-xl bg-emerald-500/10 border border-emerald-500/20 text-emerald-500 flex items-center justify-center shadow-sm">
                  <svg class="h-6 w-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
                </div>
                <span class="text-[9px] font-mono text-mute mt-1.5 font-bold">Your Device</span>
              </div>
              <div class="flex items-center gap-1">
                <span class="h-1.5 w-1.5 rounded-full bg-emerald-500 animate-pulse"></span>
                <span class="h-0.5 w-8 border-t border-dashed border-emerald-500/50"></span>
                <div class="h-6 w-6 rounded-full bg-emerald-500/10 border border-emerald-500/20 text-emerald-500 flex items-center justify-center">
                  <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
                </div>
                <span class="h-0.5 w-8 border-t border-dashed border-rose-500/30"></span>
                <span class="h-1.5 w-1.5 rounded-full bg-rose-500"></span>
              </div>
              <div class="flex flex-col items-center">
                <div class="h-12 w-12 rounded-xl bg-rose-500/10 border border-rose-500/20 text-rose-500 flex items-center justify-center opacity-65">
                  <svg class="h-6 w-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 15a4 4 0 004 4h9a5 5 0 10-.1-9.999 5.002 5.002 0 10-9.78 2.096A4.001 4.001 0 003 15z"/></svg>
                </div>
                <span class="text-[9px] font-mono text-mute mt-1.5 font-bold line-through">Database Server</span>
              </div>
            </div>
          </div>
        </div>

        <!-- Bento 3: URL State Sharing (Col Span 2) -->
        <div class="vercel-card feature-card p-6 md:col-span-2 flex flex-col justify-between" style="--card-hover-border: rgba(139, 92, 246, 0.4); --card-glow: rgba(139, 92, 246, 0.12);">
          <div>
            <div class="h-10 w-10 rounded-xl bg-violet-500/10 dark:bg-violet-500/20 text-violet-500 flex items-center justify-center mb-5 shrink-0">
              <svg class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"/>
              </svg>
            </div>
            <div class="font-mono text-xs text-mute mb-2 font-semibold">03 / STORAGELESS</div>
            <h3 class="text-lg font-bold tracking-tight text-ink">Compressed URL Share</h3>
            <p class="mt-2 text-sm text-body leading-relaxed">
              We compress your group configuration, members, and cost ledger into a lightweight, URL-safe Base64 hash. Simply copy the URL and send it to your friends to share instantly.
            </p>
          </div>

          <!-- Graphic inside card -->
          <div class="mt-6 bento-graphic h-28 flex flex-col items-center justify-center p-3">
            <div class="w-full max-w-[190px] bg-canvas rounded-md border border-hairline p-1.5 flex items-center gap-1.5 select-none shadow-sm">
              <svg class="h-3 w-3 text-mute" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>
              <div class="font-mono text-[8px] text-indigo-500 dark:text-indigo-400 truncate flex-1 leading-none">splitwhat.app/app?g=eJyrVkr...</div>
              <button class="bg-indigo-500/10 text-indigo-500 rounded px-1.5 py-0.5 text-[8px] font-bold shrink-0 hover:bg-indigo-500 hover:text-white transition-colors cursor-pointer">Copy</button>
            </div>
          </div>
        </div>

        <!-- Bento 4: Dual Splitting Modes (Col Span 2) -->
        <div class="vercel-card feature-card p-6 md:col-span-2 flex flex-col justify-between" style="--card-hover-border: rgba(245, 158, 11, 0.4); --card-glow: rgba(245, 158, 11, 0.12);">
          <div>
            <div class="h-10 w-10 rounded-xl bg-amber-500/10 dark:bg-amber-500/20 text-amber-500 flex items-center justify-center mb-5 shrink-0">
              <svg class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4"/>
              </svg>
            </div>
            <div class="font-mono text-xs text-mute mb-2 font-semibold">04 / MODULAR</div>
            <h3 class="text-lg font-bold tracking-tight text-ink">Trip vs. Subscriptions</h3>
            <p class="mt-2 text-sm text-body leading-relaxed">
              Swap layouts dynamically. Use Trip Mode for one-off group journeys (flights, dining, lodging) or Subscription Mode for monthly split recurrences (Spotify, utilities, Netflix).
            </p>
          </div>

          <!-- Interactive Graphic inside card -->
          <div class="mt-6 bento-graphic h-28 flex flex-col items-center justify-center p-3 cursor-pointer" id="bento-toggle-card">
            <div class="flex items-center gap-1.5 bg-canvas rounded-full border border-hairline p-1 shadow-sm mb-3">
              <button id="bento-trip-tab" class="rounded-full px-3 py-1 text-[9px] font-bold text-white bg-amber-500 shadow-sm transition-all select-none">Trip</button>
              <button id="bento-sub-tab" class="rounded-full px-3 py-1 text-[9px] font-bold text-body hover:text-ink transition-all select-none">Sub</button>
            </div>
            <div id="bento-mode-icons" class="flex gap-4 text-amber-500 transition-all duration-300">
              <span>✈️ Flight</span>
              <span>🏨 Hotel</span>
              <span>🚕 Taxi</span>
            </div>
          </div>
        </div>

        <!-- Bento 5: PDFs & QR Sharing (Col Span 2) -->
        <div class="vercel-card feature-card p-6 md:col-span-2 flex flex-col justify-between" style="--card-hover-border: rgba(14, 165, 233, 0.4); --card-glow: rgba(14, 165, 233, 0.12);">
          <div>
            <div class="h-10 w-10 rounded-xl bg-sky-500/10 dark:bg-sky-500/20 text-sky-500 flex items-center justify-center mb-5 shrink-0">
              <svg class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
              </svg>
            </div>
            <div class="font-mono text-xs text-mute mb-2 font-semibold">05 / PORTABLE</div>
            <h3 class="text-lg font-bold tracking-tight text-ink">Polished PDF & QR Sharing</h3>
            <p class="mt-2 text-sm text-body leading-relaxed">
              Instantly compile clean PDF logs for printing or invoice archiving, and generate clean QR codes so roommates or trip friends can scan and import the ledger onto their devices.
            </p>
          </div>

          <!-- Graphic inside card -->
          <div class="mt-6 bento-graphic h-28 flex items-center justify-center gap-4 p-3 select-none">
            <div class="w-12 h-16 bg-canvas rounded border border-hairline shadow-sm p-1.5 flex flex-col justify-between">
              <div class="space-y-0.5">
                <div class="h-1 bg-sky-500 rounded-sm w-4"></div>
                <div class="h-0.5 bg-mute rounded-sm w-8"></div>
                <div class="h-0.5 bg-mute rounded-sm w-6"></div>
              </div>
              <div class="h-3 bg-sky-500/10 rounded-sm flex items-center justify-center">
                <span class="text-[5px] text-sky-500 font-bold uppercase">PDF</span>
              </div>
            </div>
            <div class="w-14 h-14 bg-canvas rounded border border-hairline shadow-sm p-1.5 flex items-center justify-center text-sky-500">
              <svg class="h-full w-full" fill="currentColor" viewBox="0 0 24 24">
                <path d="M3 3h6v6H3V3zm2 2v2h2V5H5zm8-2h6v6h-6V3zm2 2v2h2V5h-2zM3 13h6v6H3v-6zm2 2v2h2v-2H5zm13-2h3v2h-3v-2zm-3 3h3v3h-3v-3zm3 3h3v-2h-3v2zm-3-3v-3h3v3h-3zm-2-5h2v2h-2V7zm-2 2h2v2h-2V9zm2 2h2v2h-2v-2zm2-4h2v2h-2V7zm-4-4h2v2h-2V3zm6 10h2v2h-2v-2zm-2 2h2v2h-2v-2z"/>
              </svg>
            </div>
          </div>
        </div>

        <!-- Bento 6: Smart Debt Minimization (Col Span 6) -->
        <div class="vercel-card feature-card p-8 md:col-span-6 flex flex-col md:flex-row gap-8 items-center justify-between" style="--card-hover-border: rgba(244, 63, 94, 0.4); --card-glow: rgba(244, 63, 94, 0.12);">
          <div class="flex-1 space-y-4">
            <div class="h-10 w-10 rounded-xl bg-rose-500/10 dark:bg-rose-500/20 text-rose-500 flex items-center justify-center mb-2 shrink-0">
              <svg class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/>
              </svg>
            </div>
            <div class="font-mono text-xs text-mute font-semibold">06 / ALGORITHMIC OPTIMIZATION</div>
            <h3 class="text-xl font-bold tracking-tight text-ink">Smart Debt Minimization</h3>
            <p class="text-sm text-body leading-relaxed max-w-xl">
              Why make five transactions when two can clear the board? Our core calculation engine computes the net balances of all members and pairs debtors and creditors systematically. This eliminates redundant middle-man transfers and optimizes settlement routes.
            </p>
          </div>

          <!-- Optimization comparison SVG Graphic -->
          <div class="w-full md:w-96 bento-graphic h-48 flex items-center justify-center p-4 select-none shrink-0">
            <div class="grid grid-cols-2 gap-8 w-full">
              <!-- Left Side: Unoptimized -->
