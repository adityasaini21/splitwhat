---
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <!-- Background Mesh Gradient -->
  <div class="mesh-gradient-bg"></div>

  <!-- Hero Section -->
  <section class="relative overflow-hidden py-20 sm:py-28">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-center">
        <!-- Left Side: Copy and CTAs -->
        <div class="lg:col-span-7 text-center lg:text-left space-y-6">
          <!-- Announcement Banner -->
          <div class="inline-flex items-center gap-2 rounded-full border border-hairline bg-canvas/60 backdrop-blur-md px-4 py-1.5 text-xs text-body shadow-sm mb-4 transition-all hover:border-indigo-500/30">
            <span class="relative flex h-2 w-2">
              <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-indigo-400 opacity-75"></span>
              <span class="relative inline-flex rounded-full h-2 w-2 bg-indigo-500"></span>
            </span>
            <span class="font-mono text-xs font-semibold uppercase tracking-wider text-indigo-500 dark:text-indigo-400">New Feature</span>
            <span class="h-3 w-px bg-hairline"></span>
            <span>PDF export & QR code sharing</span>
          </div>

          <!-- Tagline -->
          <h1 class="text-4xl font-bold tracking-tight text-ink sm:text-6xl max-w-3xl leading-none">
            Split bills.<br />
            Skip the login.<br />
            <span class="bg-gradient-to-r from-indigo-500 via-purple-500 to-pink-500 bg-clip-text text-transparent">Settle instantly.</span>
          </h1>
          
          <!-- Subcopy -->
          <p class="text-base sm:text-lg text-body max-w-2xl leading-relaxed">
            A privacy-first bill splitter built for trips, 
subscriptions, and shared costs. No accounts. 
No tracking. Just share a link and you're done.
          </p>

          <!-- CTA Cluster -->
          <div class="flex flex-col sm:flex-row items-center justify-center lg:justify-start gap-4 pt-4">
            <a 
              href="/app" 
              class="w-full sm:w-auto inline-flex h-12 items-center justify-center rounded-full bg-gradient-to-r from-indigo-500 to-violet-500 px-8 text-base font-semibold text-white hover:opacity-95 hover:shadow-[0_0_20px_rgba(99,102,241,0.4)] transition-all scale-100 hover:scale-105 active:scale-95"
            >
              Start Splitting Free
            </a>
            <a 
              href="#features" 
              class="w-full sm:w-auto inline-flex h-12 items-center justify-center rounded-full border border-hairline bg-canvas/60 backdrop-blur-md px-8 text-base font-semibold text-ink hover:bg-canvas-soft hover:border-indigo-500/30 transition-all scale-100 hover:scale-105 active:scale-95 shadow-sm"
            >
              See How It Works
            </a>
          </div>
        </div>

        <!-- Right Side: Floating Preview Cards (desktop only) -->
        <div class="hidden lg:block lg:col-span-5 relative h-[480px]">
          <!-- Background blob behind cards -->
          <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-72 h-72 rounded-full bg-indigo-500/10 dark:bg-indigo-500/5 filter blur-3xl pointer-events-none"></div>
          
          <!-- Card 1: Total spend summary card -->
          <div class="absolute top-8 left-0 w-72 vercel-card feature-card p-6 rotate-[-3deg] hover:rotate-0 hover:scale-105 transition-all duration-300 z-10 animate-float" style="--card-hover-border: rgba(99, 102, 241, 0.4); --card-glow: rgba(99, 102, 241, 0.12);">
            <div class="flex items-center justify-between mb-4 border-b border-hairline pb-3">
              <h3 class="text-sm font-semibold text-ink">Trip Expenses</h3>
              <span class="text-[10px] font-mono bg-canvas-soft-2 px-2 py-0.5 rounded text-body border border-hairline">3 members</span>
            </div>
            <div class="space-y-3">
              <div class="flex justify-between items-center">
                <span class="text-xs text-body">Total Spend</span>
                <span class="text-lg font-bold text-ink font-mono">$1,245.00</span>
              </div>
              <div class="flex justify-between items-center">
                <span class="text-xs text-body">Top Spender</span>
                <span class="inline-flex items-center gap-1 rounded-full bg-indigo-500/10 dark:bg-indigo-500/20 px-2 py-0.5 text-[10px] font-semibold text-indigo-500 dark:text-indigo-400">
                  Alex
                </span>
              </div>
            </div>
          </div>

          <!-- Card 2: Settlement Path display card -->
          <div class="absolute bottom-8 right-0 w-76 vercel-card feature-card p-6 rotate-[3deg] hover:rotate-0 hover:scale-105 transition-all duration-300 z-20 animate-float-reverse" style="--card-hover-border: rgba(16, 185, 129, 0.4); --card-glow: rgba(16, 185, 129, 0.12);">
            <div class="flex items-center justify-between mb-3 border-b border-hairline pb-2">
              <h3 class="text-sm font-semibold text-ink">Settlement Path</h3>
              <span class="text-[10px] font-mono text-emerald-500 font-semibold uppercase tracking-wider">Optimized</span>
            </div>
            <div class="space-y-3">
              <div class="flex items-center justify-between gap-2">
                <div class="flex items-center gap-1.5">
                  <span class="flex h-5 w-5 items-center justify-center rounded-full bg-rose-500/10 text-[10px] font-bold text-rose-500">S</span>
                  <span class="text-xs font-semibold text-ink">Sam</span>
                </div>
                <span class="text-xs text-mute flex items-center gap-1">owes <span class="animate-pulse text-indigo-500 font-bold">→</span></span>
                <div class="flex items-center gap-1.5">
                  <span class="flex h-5 w-5 items-center justify-center rounded-full bg-indigo-500/10 text-[10px] font-bold text-indigo-500">A</span>
                  <span class="text-xs font-semibold text-ink">Alex</span>
                </div>
                <span class="text-xs font-bold text-indigo-500 dark:text-indigo-400 font-mono ml-auto">$85.00</span>
              </div>
              <div class="flex items-center justify-between gap-2">
                <div class="flex items-center gap-1.5">
                  <span class="flex h-5 w-5 items-center justify-center rounded-full bg-rose-500/10 text-[10px] font-bold text-rose-500">J</span>
                  <span class="text-xs font-semibold text-ink">Jo</span>
                </div>
                <span class="text-xs text-mute flex items-center gap-1">owes <span class="animate-pulse text-indigo-500 font-bold">→</span></span>
                <div class="flex items-center gap-1.5">
                  <span class="flex h-5 w-5 items-center justify-center rounded-full bg-indigo-500/10 text-[10px] font-bold text-indigo-500">A</span>
                  <span class="text-xs font-semibold text-ink">Alex</span>
                </div>
                <span class="text-xs font-bold text-indigo-500 dark:text-indigo-400 font-mono ml-auto">$12.00</span>
              </div>
            </div>
          </div>

          <!-- Card 3: Mini Quick Log form card -->
          <div class="absolute top-36 right-12 w-64 vercel-card feature-card p-4 rotate-[-1deg] hover:rotate-0 hover:scale-105 transition-all duration-300 z-15 scale-95" style="--card-hover-border: rgba(244, 63, 94, 0.4); --card-glow: rgba(244, 63, 94, 0.12);">
            <div class="text-[9px] font-mono text-mute uppercase tracking-widest mb-2 font-semibold">Latest Expense</div>
            <div class="space-y-2">
              <div class="h-8 px-2 rounded border border-hairline bg-canvas/50 flex items-center justify-between text-xs">
                <span class="text-body font-medium">Pizza Dinner 🍕</span>
                <span class="font-mono text-ink font-semibold">$90.00</span>
              </div>
              <div class="text-[10px] text-body">Paid by Sam, split among 3.</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Feature Grid Section -->
  <section id="features" class="scroll-mt-16 border-t border-hairline bg-canvas py-20 sm:py-28">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-3xl mx-auto space-y-3">
        <p class="font-mono text-xs font-semibold uppercase tracking-wider text-indigo-500 dark:text-indigo-400">An expense splitter engineered for power users</p>
        <h2 class="text-3xl font-bold tracking-tight text-ink sm:text-4xl">
          Everything you need. Done locally.
        </h2>
        <p class="text-base text-body">
          We stripped away the database, the signup forms, and the latency. You get pure utility.
        </p>
      </div>

      <div class="mt-16 grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
        <!-- Feature 1 -->
        <div class="vercel-card feature-card p-6" style="--card-hover-border: rgba(99, 102, 241, 0.4); --card-glow: rgba(99, 102, 241, 0.12);">
          <div class="h-10 w-10 rounded-xl bg-indigo-500/10 dark:bg-indigo-500/20 text-indigo-500 flex items-center justify-center mb-5 shrink-0">
            <svg class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z"/>
            </svg>
          </div>
          <div class="font-mono text-xs text-mute mb-2 font-semibold">01 / SPEED</div>
          <h3 class="text-lg font-bold tracking-tight text-ink">No Accounts Required</h3>
          <p class="mt-2 text-sm text-body">
            Skip the sign-up flow. Start splitting bills instantly the second you open the app.
          </p>
        </div>

        <!-- Feature 2 -->
        <div class="vercel-card feature-card p-6" style="--card-hover-border: rgba(16, 185, 129, 0.4); --card-glow: rgba(16, 185, 129, 0.12);">
          <div class="h-10 w-10 rounded-xl bg-emerald-500/10 dark:bg-emerald-500/20 text-emerald-500 flex items-center justify-center mb-5 shrink-0">
            <svg class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
            </svg>
          </div>
          <div class="font-mono text-xs text-mute mb-2 font-semibold">02 / PRIVACY</div>
          <h3 class="text-lg font-bold tracking-tight text-ink">100% Client-Side</h3>
          <p class="mt-2 text-sm text-body">
            All data is saved in your local browser storage. No servers, no tracking, completely secure.
          </p>
        </div>

        <!-- Feature 3 -->
        <div class="vercel-card feature-card p-6" style="--card-hover-border: rgba(139, 92, 246, 0.4); --card-glow: rgba(139, 92, 246, 0.12);">
          <div class="h-10 w-10 rounded-xl bg-violet-500/10 dark:bg-violet-500/20 text-violet-500 flex items-center justify-center mb-5 shrink-0">
            <svg class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"/>
            </svg>
          </div>
          <div class="font-mono text-xs text-mute mb-2 font-semibold">03 / COLLABORATION</div>
          <h3 class="text-lg font-bold tracking-tight text-ink">URL State Sharing</h3>
          <p class="mt-2 text-sm text-body">
            Encode your split state inside a compressed URL param. Just copy the link and send it.
          </p>
        </div>

        <!-- Feature 4 -->
        <div class="vercel-card feature-card p-6" style="--card-hover-border: rgba(245, 158, 11, 0.4); --card-glow: rgba(245, 158, 11, 0.12);">
          <div class="h-10 w-10 rounded-xl bg-amber-500/10 dark:bg-amber-500/20 text-amber-500 flex items-center justify-center mb-5 shrink-0">
            <svg class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4"/>
            </svg>
          </div>
          <div class="font-mono text-xs text-mute mb-2 font-semibold">04 / VERSATILITY</div>
          <h3 class="text-lg font-bold tracking-tight text-ink">Dual Splitting Modes</h3>
          <p class="mt-2 text-sm text-body">
            Toggle between subscription mode for recurring costs or travel mode for group trips.
          </p>
        </div>

        <!-- Feature 5 -->
        <div class="vercel-card feature-card p-6" style="--card-hover-border: rgba(244, 63, 94, 0.4); --card-glow: rgba(244, 63, 94, 0.12);">
          <div class="h-10 w-10 rounded-xl bg-rose-500/10 dark:bg-rose-500/20 text-rose-500 flex items-center justify-center mb-5 shrink-0">
            <svg class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/>
            </svg>
          </div>
          <div class="font-mono text-xs text-mute mb-2 font-semibold">05 / MATHEMATICS</div>
          <h3 class="text-lg font-bold tracking-tight text-ink">Smart Debt Minimization</h3>
          <p class="mt-2 text-sm text-body">
            Our settlement algorithm computes the minimum number of payments needed to clear all debts.
          </p>
        </div>

        <!-- Feature 6 -->
        <div class="vercel-card feature-card p-6" style="--card-hover-border: rgba(14, 165, 233, 0.4); --card-glow: rgba(14, 165, 233, 0.12);">
          <div class="h-10 w-10 rounded-xl bg-sky-500/10 dark:bg-sky-500/20 text-sky-500 flex items-center justify-center mb-5 shrink-0">
            <svg class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
            </svg>
          </div>
          <div class="font-mono text-xs text-mute mb-2 font-semibold">06 / EXPORT</div>
          <h3 class="text-lg font-bold tracking-tight text-ink">PDFs & QR Codes</h3>
          <p class="mt-2 text-sm text-body">
            Export a high-quality PDF report or show a QR code for mobile scanning instantly.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- How It Works Section -->
  <section class="border-t border-hairline bg-canvas-soft py-20 sm:py-28">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-3xl mx-auto space-y-2">
        <p class="font-mono text-xs font-semibold uppercase tracking-wider text-indigo-500 dark:text-indigo-400">Simple Workflow</p>
        <h2 class="text-3xl font-bold tracking-tight text-ink sm:text-4xl">
          Three steps to settlement.
        </h2>
      </div>

      <div class="mt-16 grid grid-cols-1 gap-8 md:grid-cols-3">
        <!-- Step 1 -->
        <div class="flex flex-col items-start p-6 vercel-card feature-card" style="--card-hover-border: rgba(99, 102, 241, 0.4); --card-glow: rgba(99, 102, 241, 0.1);">
          <div class="flex h-8 w-8 items-center justify-center rounded-full bg-gradient-to-r from-indigo-500 to-violet-500 font-mono text-xs font-bold text-white mb-6 shadow-md">1</div>
          <h3 class="text-lg font-bold text-ink">Create Group & Add Members</h3>
          <p class="mt-2 text-sm text-body">
            Enter a group name, pick your currency, and add up to 30 members. No signup required.
          </p>
        </div>

        <!-- Step 2 -->
        <div class="flex flex-col items-start p-6 vercel-card feature-card" style="--card-hover-border: rgba(139, 92, 246, 0.4); --card-glow: rgba(139, 92, 246, 0.1);">
          <div class="flex h-8 w-8 items-center justify-center rounded-full bg-gradient-to-r from-violet-500 to-fuchsia-500 font-mono text-xs font-bold text-white mb-6 shadow-md">2</div>
          <h3 class="text-lg font-bold text-ink">Log Group Expenses</h3>
          <p class="mt-2 text-sm text-body">
            Add bills, titles, and amounts. Choose who paid and select which members split the expense.
          </p>
        </div>

        <!-- Step 3 -->
        <div class="flex flex-col items-start p-6 vercel-card feature-card" style="--card-hover-border: rgba(236, 72, 153, 0.4); --card-glow: rgba(236, 72, 153, 0.1);">
          <div class="flex h-8 w-8 items-center justify-center rounded-full bg-gradient-to-r from-fuchsia-500 to-pink-500 font-mono text-xs font-bold text-white mb-6 shadow-md">3</div>
          <h3 class="text-lg font-bold text-ink">Share & Settle Up</h3>
          <p class="mt-2 text-sm text-body">
            View the minimal payment matrix. Share the link, display the QR code, or export to PDF.
          </p>
        </div>
      </div>

      <div class="mt-12 text-center">
        <a 
          href="/app" 
          class="inline-flex h-12 items-center justify-center rounded-full bg-gradient-to-r from-indigo-500 to-violet-500 px-8 text-sm font-semibold text-white hover:opacity-95 hover:shadow-[0_0_20px_rgba(99,102,241,0.4)] scale-100 hover:scale-105 active:scale-95 transition-all"
        >
          Launch App Free
        </a>
      </div>
    </div>
  </section>

  <!-- FAQ Section -->
  <section class="border-t border-hairline bg-canvas py-20 sm:py-28">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-3xl">
        <h2 class="text-3xl font-bold tracking-tight text-ink text-center mb-12">Frequently Asked Questions</h2>
        
        <div class="space-y-4">
          <!-- FAQ 1 -->
          <div class="faq-item border border-hairline bg-canvas-soft rounded-2xl p-5 transition-all duration-300 hover:border-indigo-500/30 group">
            <button class="faq-trigger flex w-full items-center justify-between text-left font-bold text-ink focus:outline-none cursor-pointer">
              <span>Where is my data stored?</span>
              <svg class="h-4 w-4 text-mute group-hover:text-indigo-500 transition-transform duration-300 transform group-[.open]:rotate-180" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
              </svg>
            </button>
            <div class="faq-content overflow-hidden max-h-0 transition-all duration-300 ease-in-out">
              <p class="mt-3 text-sm text-body leading-relaxed">
                All calculations and data exist entirely in your browser. We use local storage to save your groups. We do not use any databases or servers, keeping your financial activities private.
              </p>
            </div>
          </div>

          <!-- FAQ 2 -->
          <div class="faq-item border border-hairline bg-canvas-soft rounded-2xl p-5 transition-all duration-300 hover:border-indigo-500/30 group">
            <button class="faq-trigger flex w-full items-center justify-between text-left font-bold text-ink focus:outline-none cursor-pointer">
              <span>How does sharing work without a backend database?</span>
              <svg class="h-4 w-4 text-mute group-hover:text-indigo-500 transition-transform duration-300 transform group-[.open]:rotate-180" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
              </svg>
            </button>
            <div class="faq-content overflow-hidden max-h-0 transition-all duration-300 ease-in-out">
              <p class="mt-3 text-sm text-body leading-relaxed">
                We compress the entire group state (members, expenses, and config) into a short base64 string using `lz-string`. We append this string as a URL query parameter. When someone opens your shared link, the app extracts, decompresses, and loads it instantly.
              </p>
            </div>
          </div>

          <!-- FAQ 3 -->
          <div class="faq-item border border-hairline bg-canvas-soft rounded-2xl p-5 transition-all duration-300 hover:border-indigo-500/30 group">
            <button class="faq-trigger flex w-full items-center justify-between text-left font-bold text-ink focus:outline-none cursor-pointer">
              <span>Is SplitWhat really free?</span>
              <svg class="h-4 w-4 text-mute group-hover:text-indigo-500 transition-transform duration-300 transform group-[.open]:rotate-180" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
              </svg>
            </button>
            <div class="faq-content overflow-hidden max-h-0 transition-all duration-300 ease-in-out">
              <p class="mt-3 text-sm text-body leading-relaxed">
                Yes, it is 100% free. There are no premium tiers, no limits on number of groups, and absolutely no ads.
              </p>
            </div>
          </div>

          <!-- FAQ 4 -->
          <div class="faq-item border border-hairline bg-canvas-soft rounded-2xl p-5 transition-all duration-300 hover:border-indigo-500/30 group">
            <button class="faq-trigger flex w-full items-center justify-between text-left font-bold text-ink focus:outline-none cursor-pointer">
              <span>Can I use SplitWhat offline?</span>
              <svg class="h-4 w-4 text-mute group-hover:text-indigo-500 transition-transform duration-300 transform group-[.open]:rotate-180" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
              </svg>
            </button>
            <div class="faq-content overflow-hidden max-h-0 transition-all duration-300 ease-in-out">
              <p class="mt-3 text-sm text-body leading-relaxed">
                Yes. Since the app is built on Astro and uses 100% client-side logic for parsing, compiling, QR generating, and PDF printing, it runs perfectly without an active internet connection.
              </p>
            </div>
          </div>

          <!-- FAQ 5 -->
          <div class="faq-item border border-hairline bg-canvas-soft rounded-2xl p-5 transition-all duration-300 hover:border-indigo-500/30 group">
            <button class="faq-trigger flex w-full items-center justify-between text-left font-bold text-ink focus:outline-none cursor-pointer">
              <span>What happens if the sharing link gets too long?</span>
              <svg class="h-4 w-4 text-mute group-hover:text-indigo-500 transition-transform duration-300 transform group-[.open]:rotate-180" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
              </svg>
            </button>
            <div class="faq-content overflow-hidden max-h-0 transition-all duration-300 ease-in-out">
              <p class="mt-3 text-sm text-body leading-relaxed">
                Since the entire data is stored in the URL, a huge number of expenses will make the URL very long. We show a friendly warning if the URL exceeds 2,000 characters. To prevent this, keep your group lists under 300 expenses.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <script>
    const faqTriggers = document.querySelectorAll('.faq-trigger');
    faqTriggers.forEach(trigger => {
      trigger.addEventListener('click', () => {
        const item = trigger.closest('.faq-item')!;
        const content = item.querySelector('.faq-content') as HTMLDivElement;
        const isOpen = item.classList.contains('open');
        
        // Close all other items
        document.querySelectorAll('.faq-item').forEach(otherItem => {
          if (otherItem !== item) {
            otherItem.classList.remove('open');
            (otherItem.querySelector('.faq-content') as HTMLDivElement).style.maxHeight = '0px';
          }
        });
        
        if (isOpen) {
          item.classList.remove('open');
          content.style.maxHeight = '0px';
        } else {
          item.classList.add('open');
          content.style.maxHeight = content.scrollHeight + 'px';
        }
      });
    });
  </script>
</Layout>
