  <script>
    // FAQ Accordion Trigger
    const faqTriggers = document.querySelectorAll('.faq-trigger');
    faqTriggers.forEach(trigger => {
      trigger.addEventListener('click', () => {
        const item = trigger.closest('.faq-item')!;
        const content = item.querySelector('.faq-content') as HTMLDivElement;
        const isOpen = item.classList.contains('open');
        
        // Close all other items
        document.querySelectorAll('.faq-item').forEach(otherItem => {
          if (otherItem !== item) {
            otherItem.classList.remove('open');
            (otherItem.querySelector('.faq-content') as HTMLDivElement).style.maxHeight = '0px';
          }
        });
        
        if (isOpen) {
          item.classList.remove('open');
          content.style.maxHeight = '0px';
        } else {
          item.classList.add('open');
          content.style.maxHeight = content.scrollHeight + 'px';
        }
      });
    });

    // Bento Card Mode Switcher Demo
    const bentoCard = document.getElementById('bento-toggle-card');
    const bentoTripTab = document.getElementById('bento-trip-tab');
    const bentoSubTab = document.getElementById('bento-sub-tab');
    const bentoModeIcons = document.getElementById('bento-mode-icons');
    
    if (bentoCard && bentoTripTab && bentoSubTab && bentoModeIcons) {
      const toggleBentoMode = (mode: 'trip' | 'sub') => {
        if (mode === 'trip') {
          bentoTripTab.className = 'rounded-full px-3 py-1 text-[9px] font-bold text-white bg-amber-500 shadow-sm transition-all select-none';
          bentoSubTab.className = 'rounded-full px-3 py-1 text-[9px] font-bold text-body hover:text-ink transition-all select-none';
          bentoModeIcons.innerHTML = '<span>✈️ Flight</span> <span>🏨 Hotel</span> <span>🚕 Taxi</span>';
          bentoModeIcons.className = 'flex gap-4 text-amber-500 transition-all duration-300';
        } else {
          bentoSubTab.className = 'rounded-full px-3 py-1 text-[9px] font-bold text-white bg-amber-500 shadow-sm transition-all select-none';
          bentoTripTab.className = 'rounded-full px-3 py-1 text-[9px] font-bold text-body hover:text-ink transition-all select-none';
          bentoModeIcons.innerHTML = '<span>🎵 Spotify</span> <span>📺 Netflix</span> <span>🏠 Rent</span>';
          bentoModeIcons.className = 'flex gap-4 text-violet-500 transition-all duration-300';
        }
      };
      
      bentoTripTab.addEventListener('click', (e) => {
        e.stopPropagation();
        toggleBentoMode('trip');
      });
      
      bentoSubTab.addEventListener('click', (e) => {
        e.stopPropagation();
        toggleBentoMode('sub');
      });
      
      bentoCard.addEventListener('click', () => {
        const isTrip = bentoTripTab.classList.contains('bg-amber-500');
        toggleBentoMode(isTrip ? 'sub' : 'trip');
      });
    }

    // Live Simulator Logic
    interface SimExpense {
      id: string;
      title: string;
      amount: number;
      paidBy: string;
    }

    const simExpenses: SimExpense[] = [
      { id: '1', title: 'Airbnb 🏠', amount: 150, paidBy: 'Alex' },
      { id: '2', title: 'Dinner 🍕', amount: 45, paidBy: 'Sam' }
    ];
    
    const simMembers = ['Alex', 'Sam', 'Jo'];
    
    function renderSimulator() {
      const listContainer = document.getElementById('sim-expenses-list');
      const settleContainer = document.getElementById('sim-settlements-list');
      if (!listContainer || !settleContainer) return;
      
      // Render expense list
      listContainer.innerHTML = '';
      simExpenses.forEach((exp, idx) => {
        const item = document.createElement('div');
        item.className = 'flex justify-between items-center text-xs bg-canvas/60 border border-hairline p-2 rounded-xl transition-all duration-300 hover:border-indigo-500/20';
        item.innerHTML = `
          <div class="min-w-0 flex-1">
            <p class="font-semibold text-ink truncate">${exp.title}</p>
            <p class="text-[8px] text-mute font-mono">Paid by ${exp.paidBy}</p>
          </div>
          <div class="flex items-center gap-2 pl-2">
            <span class="font-mono font-bold text-ink">$${exp.amount}</span>
            <button class="sim-del-btn text-mute hover:text-rose-500 text-[12px] font-bold px-1 cursor-pointer" data-idx="${idx}">&times;</button>
          </div>
        `;
        listContainer.appendChild(item);
      });
      
      // Calculate balances
      const balances: Record<string, number> = {};
      simMembers.forEach(m => balances[m] = 0);
      
      simExpenses.forEach(exp => {
        const amount = exp.amount;
        const paidBy = exp.paidBy;
        
        balances[paidBy] += amount;
        
        // Split equally among all members
        const share = amount / simMembers.length;
        simMembers.forEach(m => {
          balances[m] -= share;
        });
      });
      
      // Greedy settlement
      interface DebtPerson {
        name: string;
        balance: number;
      }
      const debtors: DebtPerson[] = [];
      const creditors: DebtPerson[] = [];
      simMembers.forEach(m => {
        const bal = balances[m];
        if (bal < -0.01) debtors.push({ name: m, balance: -bal });
        else if (bal > 0.01) creditors.push({ name: m, balance: bal });
      });
      
      debtors.sort((a, b) => b.balance - a.balance);
      creditors.sort((a, b) => b.balance - a.balance);
      
      interface Settlement {
        from: string;
        to: string;
        amount: number;
      }
      const settlements: Settlement[] = [];
      let d = 0, c = 0;
      while (d < debtors.length && c < creditors.length) {
        const debtor = debtors[d];
        const creditor = creditors[c];
        const flow = Math.min(debtor.balance, creditor.balance);
        
        settlements.push({ from: debtor.name, to: creditor.name, amount: flow });
        
        debtor.balance -= flow;
        creditor.balance -= flow;
        if (debtor.balance < 0.01) d++;
        if (creditor.balance < 0.01) c++;
      }
      
      // Render settlements
      settleContainer.innerHTML = '';
      if (settlements.length === 0) {
        settleContainer.innerHTML = `
          <div class="h-full flex flex-col items-center justify-center text-center p-4">
            <span class="text-xs text-mute font-mono">All settled!</span>
          </div>
        `;
      } else {
        settlements.forEach(set => {
          const item = document.createElement('div');
          item.className = 'flex items-center justify-between gap-1 text-[11px] bg-indigo-500/[0.03] border border-indigo-500/10 p-2 rounded-xl';
          item.innerHTML = `
            <div class="flex items-center gap-1 min-w-0">
              <span class="font-semibold text-ink truncate">${set.from}</span>
              <span class="text-[9px] text-mute font-mono">owes</span>
              <span class="font-semibold text-ink truncate">${set.to}</span>
            </div>
            <span class="font-mono font-bold text-indigo-500 dark:text-indigo-400 shrink-0">$${set.amount.toFixed(2)}</span>
          `;
          settleContainer.appendChild(item);
        });
      }
      
      // Add delete listeners
      document.querySelectorAll('.sim-del-btn').forEach(btn => {
        btn.addEventListener('click', (e) => {
          const idx = parseInt((e.currentTarget as HTMLButtonElement).dataset.idx!);
          simExpenses.splice(idx, 1);
          renderSimulator();
        });
      });
    }

    // Set up form submission hook
    const addBtn = document.getElementById('sim-add-btn');
    if (addBtn) {
      addBtn.addEventListener('click', () => {
        const descInput = document.getElementById('sim-desc') as HTMLInputElement;
        const amountInput = document.getElementById('sim-amount') as HTMLInputElement;
        const paidSelect = document.getElementById('sim-paid-by') as HTMLSelectElement;
        
        if (!descInput || !amountInput || !paidSelect) return;
        
        const title = descInput.value.trim() || 'Expense';
        const amount = parseFloat(amountInput.value) || 0;
        const paidBy = paidSelect.value;
        
        if (amount <= 0) return;
        
        simExpenses.push({
          id: Math.random().toString(),
          title,
          amount,
          paidBy
        });
        
        // Reset inputs
        descInput.value = '';
        amountInput.value = '';
        
        renderSimulator();
      });
    }

    // Initial render
    renderSimulator();
  </script>

